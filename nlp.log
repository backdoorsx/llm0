def forward(self, x):

    positions = np.arange(x.shape[0])[:, None]
    x = x + np.sin(positions * 0.1)

    Q = x @ self.Wq
    K = x @ self.Wk
    V = x @ self.Wv

    scores = Q @ K.T / np.sqrt(self.dim)

    n = scores.shape[0]

    mask = np.triu(np.ones((n, n)), k=1)

    scores = scores - 1e9 * mask

    attn = np.zeros_like(scores)

    for i in range(n):
        attn[i] = self.softmax(scores[i])

    out = attn @ V

    # residual connection
    out = out + x

    return out

