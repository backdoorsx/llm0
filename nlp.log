    """

    # =========================
    # DEBUG INPUT
    # =========================

    if debug:
        print("\n==============================")
        print("INPUT IDS:", x)
        print("INPUT WORDS:", [idx2word[i] for i in x])

    # =========================
    # EMBEDDINGS
    # =========================

