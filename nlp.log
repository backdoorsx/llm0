class SimpleClassifierLLM:
    """
    Jednoduchy jazykovy classifier.

    Uloha:
        zo sentence vectoru predpoveda dalsie slovo

    Architektura:
        sentence_vector → linear layer → softmax
    """

    def __init__(self, embed_dim, vocab_size):
        """
        Inicializacia vah.

        W: matica vah (embed_dim x vocab_size)
        b: bias (vocab_size)
        """

        self.W = np.random.randn(embed_dim, vocab_size) * 0.01
        self.b = np.zeros(vocab_size)

    def forward(self, sentence_vec):
        """
        Dopredny vypocet.

        Vstup:
            sentence_vec (np.array): tvar (embed_dim,)

        Vystup:
            probs (np.array): pravdepodobnosti slov
        """

        logits = sentence_vec @ self.W + self.b

        exp = np.exp(logits - np.max(logits))
        probs = exp / np.sum(exp)

        return probs

