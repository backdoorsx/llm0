    if debug:
        print("\nEMBEDDINGS SHAPE:", emb.shape)

    # =========================
    # TRANSFORMER FORWARD
    # =========================

    out = transformer.forward(emb)

    # posledný token ako reprezentácia
    h = out[-1]

    # 🔥 FIX SHAPE BUG (TOTO TI PADALO)
    h = np.asarray(h).reshape(-1)

    if debug:
        print("\nH SHAPE AFTER FIX:", h.shape)

    # =========================
    # CLASSIFIER FORWARD
    # =========================

    logits = h @ classifier.W + classifier.b

    probs = np.exp(logits - np.max(logits))
    probs = probs / np.sum(probs)

    # =========================
    # LOSS
    # =========================

    loss = -np.log(probs[y_idx] + 1e-9)

    if debug:
        print("\nLOSS:", loss)
        print("TARGET:", idx2word[y_idx])

    # =========================
    # GRADIENT (softmax CE)
    # =========================

    dlogits = probs.copy()
    dlogits[y_idx] -= 1

    # =========================
    # CLASSIFIER BACKPROP
    # =========================

    dW = np.outer(h, dlogits)
    db = dlogits

    dh = classifier.W @ dlogits

    classifier.W -= lr * dW
    classifier.b -= lr * db

    # =========================
    # TRANSFORMER BACKPROP (simplified Q/K/V learning)
    # =========================

    n, d = emb.shape
    last_emb = emb[-1]

    # V gradient
    dWv = np.outer(last_emb, dh)

    # Q/K approximate gradients
    qk_signal = dh

    dWq = np.zeros_like(transformer.Wq)
    dWk = np.zeros_like(transformer.Wk)

    for i in range(n):
        dWq += np.outer(emb[i], qk_signal @ transformer.Wk.T)
        dWk += np.outer(emb[i], qk_signal @ transformer.Wq.T)

    # =========================
    # APPLY UPDATES
    # =========================

    transformer.Wv -= lr * dWv
    transformer.Wq -= lr * dWq * 0.01
    transformer.Wk -= lr * dWk * 0.01

    # =========================
    # EMBEDDING BACKPROP
    # =========================

    embedding.update(x, dh / len(x), lr)

    return loss

