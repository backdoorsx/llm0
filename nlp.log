🧠 1. Priprav dataset (kľúčové)

Pridaj túto funkciu:

def build_language_dataset(data, word2idx):
    pairs = []

    for inp, out in data:
        tokens = tokenize(inp) + tokenize(out)

        encoded = encode_oov(tokens, word2idx)

        for i in range(1, len(encoded)):
            x = encoded[:i]      # vstup
            y = encoded[i]      # next word
            pairs.append((x, y))

    return pairs

🧠 2. Tréning (takmer rovnaký)

Použi tvoj train_step, nič zásadné nemeníš.

def train_lm(embedding, classifier, pairs, idx2word, epochs=300, lr=0.05):
    for epoch in range(epochs):
        total_loss = 0

        for x, y in pairs:
            loss = train_step(embedding, classifier, x, y, lr, idx2word)
            total_loss += loss

        if epoch % 50 == 0:
            print("epoch", epoch, "loss", total_loss / len(pairs))

🧠 3. Predikcia next word

def predict_next(embedding, classifier, text, word2idx, idx2word):
    x = encode_oov(tokenize(text), word2idx)

    emb = embedding.forward(x)
    h = mean_pooling(emb)

    probs = classifier.forward(h)

    idx = np.argmax(probs)

    return idx2word[idx]

🧠 4. Generovanie vety (WOW moment)

def generate(embedding, classifier, text, word2idx, idx2word, max_len=10):
    words = tokenize(text)

    for _ in range(max_len):
        next_word = predict_next(
            embedding, classifier,
            " ".join(words),
            word2idx, idx2word
        )
        words.append(next_word)

    return " ".join(words)

🚀 5. Použitie

data = load_dataset("datasetllm.json")

word2idx, idx2word = build_vocab(data)

pairs = build_language_dataset(data, word2idx)

embedding = Embedding(len(word2idx), 16)
classifier = SimpleClassifierLLM(16, len(word2idx))

train_lm(embedding, classifier, pairs, idx2word, epochs=500, lr=0.03)

print(generate(embedding, classifier, "ahoj ako", word2idx, idx2word))

