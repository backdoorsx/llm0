import json

def load_dataset(path):
    """
    Nacita dataset zo JSON suboru.

    Vstup:
        path (str): cesta k JSON suboru

    Vystup:
        list[tuple]: zoznam (input, output) dvojic

    Format JSON:
        [{"input": "...", "output": "..."}, ...]
    """

    with open(path, "r", encoding="utf-8") as f:
        raw_data = json.load(f)

    data = []
    for item in raw_data:
        data.append((item["input"], item["output"]))

    return data

