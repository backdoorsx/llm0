import numpy as np
import json
from collections import Counter

# ---------------------------
# EMBEDDING LAYER
# ---------------------------
class Embedding:
    def __init__(self, vocab_size, dim):
        self.vocab_size = vocab_size
        self.dim = dim
        self.E = np.random.randn(vocab_size, dim) * (1 / np.sqrt(dim))

    def forward(self, x):
        return self.E[x]

    def update(self, x, grad, lr):
        for i, idx in enumerate(x):
            self.E[idx] -= lr * grad[i]

# ---------------------------
# LAYER NORM
# ---------------------------
class LayerNorm:
    def __init__(self, dim, eps=1e-5):
        self.eps = eps
        self.gamma = np.ones(dim)
        self.beta = np.zeros(dim)

    def forward(self, x):
        self.mean = x.mean(axis=-1, keepdims=True)
        self.var = x.var(axis=-1, keepdims=True)
        self.x_norm = (x - self.mean) / np.sqrt(self.var + self.eps)
        return self.gamma * self.x_norm + self.beta

    def backward(self, d_out, lr):
        N, D = d_out.shape
        x_mu = self.x_norm
        std_inv = 1. / np.sqrt(self.var + self.eps)
        
        dx_norm = d_out * self.gamma
        dvar = np.sum(dx_norm * (self.x_norm * -0.5 * std_inv), axis=-1, keepdims=True)
        dmean = np.sum(-dx_norm * std_inv, axis=-1, keepdims=True) + dvar * np.mean(-2. * self.x_norm, axis=-1, keepdims=True)
        dx = dx_norm * std_inv + dvar * 2 * self.x_norm / D + dmean / D
        # update gamma, beta
        self.gamma -= lr * np.sum(d_out * self.x_norm, axis=0)
        self.beta -= lr * np.sum(d_out, axis=0)
        return dx

# ---------------------------
# MINI TRANSFORMER BLOCK
# ---------------------------
class MiniTransformerBlock:
    def __init__(self, dim):
        self.dim = dim
        self.Wq = np.random.randn(dim, dim) * 0.01
        self.Wk = np.random.randn(dim, dim) * 0.01
        self.Wv = np.random.randn(dim, dim) * 0.01
        self.ln1 = LayerNorm(dim)
        self.ln2 = LayerNorm(dim)
        self.Wo = np.random.randn(dim, dim) * 0.01
        self.W1 = np.random.randn(dim, dim*4) * 0.01
        self.W2 = np.random.randn(dim*4, dim) * 0.01

    def softmax(self, x):
        x = x - np.max(x, axis=-1, keepdims=True)
        e = np.exp(x)
        return e / np.sum(e, axis=-1, keepdims=True)

    def forward(self, x):
        # x: (seq_len, dim)
        # Self-attention
        Q = x @ self.Wq
        K = x @ self.Wk
        V = x @ self.Wv

        scores = (Q @ K.T) / np.sqrt(self.dim)
        mask = np.triu(np.ones(scores.shape), k=1) * 1e9
        scores = scores - mask

        attn = self.softmax(scores)
        out_attn = attn @ V
        out_attn = out_attn @ self.Wo

        # Residual + LayerNorm
        x = self.ln1.forward(x + out_attn)

        # Feed-forward
        ff = np.tanh(x @ self.W1) @ self.W2
        x = self.ln2.forward(x + ff)

        self.cache = (x, Q, K, V, attn, out_attn, ff)
        return x

    # Note: backward omitted for brevity, we can use simple SGD on embeddings + classifier for now

# ---------------------------
# SIMPLE CLASSIFIER
# ---------------------------
class SimpleClassifier:
    def __init__(self, dim, vocab_size):
        self.W = np.random.randn(dim, vocab_size) * 0.01
        self.b = np.zeros(vocab_size)

    def forward(self, h):
        logits = h @ self.W + self.b
        exp = np.exp(logits - np.max(logits))
        return exp / np.sum(exp)

    def backward(self, h, probs, target, lr):
        dlogits = probs.copy()
        dlogits[target] -= 1
        dW = np.outer(h, dlogits)
        db = dlogits
        dh = self.W @ dlogits
        self.W -= lr * dW
        self.b -= lr * db
        return dh

# ---------------------------
# HELPERS
# ---------------------------
def tokenize(text):
    return text.lower().split()

def encode_oov(tokens, word2idx):
    unk = word2idx["<UNK>"]
    return [word2idx.get(t, unk) for t in tokens]

def softmax(x):
    x = x - np.max(x)
    e = np.exp(x)
    return e / np.sum(e)

def sample_top_k(probs, top_k=3, temperature=1.0):
    probs = np.log(probs + 1e-9) / temperature
    probs = np.exp(probs)
    probs /= np.sum(probs)
    top_idx = np.argsort(probs)[-top_k:]
    top_probs = probs[top_idx]
    top_probs /= np.sum(top_probs)
    return np.random.choice(top_idx, p=top_probs)

# ---------------------------
# TRAINING STEP
# ---------------------------
def train_step(embedding, transformer, classifier, x, y, lr=0.01):
    emb = embedding.forward(x)
    out = transformer.forward(emb)
    h = out[-1]
    probs = classifier.forward(h)
    loss = -np.log(probs[y] + 1e-9)
    dh = classifier.backward(h, probs, y, lr)
    # distribute dh to embedding
    for i, idx in enumerate(x):
        embedding.E[idx] -= lr * dh / len(x)
    return loss

# ---------------------------
# GENERATE
# ---------------------------
def generate(embedding, transformer, classifier, text, word2idx, idx2word, max_len=10):
    words = tokenize(text)
    for _ in range(max_len):
        x = encode_oov(words, word2idx)
        emb = embedding.forward(x)
        out = transformer.forward(emb)
        h = out[-1]
        probs = classifier.forward(h)
        idx = sample_top_k(probs, top_k=3, temperature=1.0)
        words.append(idx2word[idx])
    return " ".join(words)

# ---------------------------
# VOCAB + DATASET
# ---------------------------
def build_vocab(data, min_freq=1):
    counter = Counter()
    for text in data:
        counter.update(tokenize(text))
    vocab = ["<PAD>", "<UNK>"] + [w for w, f in counter.items() if f >= min_freq]
    word2idx = {w:i for i,w in enumerate(vocab)}
    idx2word = {i:w for w,i in word2idx.items()}
    return word2idx, idx2word

# ---------------------------
# MAIN EXAMPLE
# ---------------------------
if __name__ == "__main__":
    # 1) LOAD DATASET (text-only)
    data = load_dataset("datasetllm2.json")

    # 2) BUILD VOCAB
    word2idx, idx2word = build_vocab(data)

    # 3) BUILD TRAINING PAIRS (next-token dataset)
    pairs = build_language_dataset(data, word2idx)

    # 4) INIT MODEL
    embedding = Embedding(len(word2idx), 16)
    transformer = MiniTransformerBlock(16)
    classifier = SimpleClassifier(16, len(word2idx))

    # 5) TRAIN
    train_lm_transformer(
        embedding,
        transformer,
        classifier,
        pairs,
        epochs=600,
        lr=0.01
    )

    # 6) GENERATE
    print(
        generate(
            embedding,
            transformer,
            classifier,
            "ahoj ako",
            word2idx,
            idx2word,
            max_len=10
        )
    )

