🔥 1. MiniTransformerTrainable.forward (FIX causal + stabilita)

def forward(self, x):
    Q = x @ self.Wq
    K = x @ self.Wk
    V = x @ self.Wv

    scores = (Q @ K.T) / np.sqrt(self.dim)

    # causal mask
    n = scores.shape[0]
    mask = np.triu(np.ones((n, n)), k=1)
    scores = scores - 1e9 * mask

    attn = self.softmax(scores)
    out = attn @ V

    cache = (x, Q, K, V, attn)
    return out, cache

🔥 2. MiniTransformerTrainable.backward (FIX učenia cez celý sequence)

def backward(self, dout, cache, lr=0.01):
    x, Q, K, V, attn = cache
    n = x.shape[0]

    dV = attn.T @ dout
    datt = dout @ V.T

    dscores = np.zeros_like(datt)

    for i in range(n):
        a = attn[i][:, None]
        da = datt[i][:, None]
        dscores[i] = (np.diagflat(a) - a @ a.T) @ da[:, 0]

    dQ = dscores @ K / np.sqrt(self.dim)
    dK = dscores.T @ Q / np.sqrt(self.dim)

    dWq = x.T @ dQ
    dWk = x.T @ dK
    dWv = x.T @ dV

    self.Wq -= lr * dWq
    self.Wk -= lr * dWk
    self.Wv -= lr * dWv

    dx = dQ @ self.Wq.T + dK @ self.Wk.T + dV @ self.Wv.T
    return dx

🔥 3. train_step_transformer (FIX learning signálu)

def train_step_transformer(embedding, transformer, classifier, x, y_idx, lr):
    emb = embedding.forward(x)

    out, cache = transformer.forward(emb)

    # GPT štýl: posledný token = kontext
    h = out[-1]

    logits = h @ classifier.W + classifier.b
    probs = np.exp(logits - np.max(logits))
    probs /= np.sum(probs)

    loss = -np.log(probs[y_idx] + 1e-9)

    dlogits = probs.copy()
    dlogits[y_idx] -= 1

    dW = np.outer(h, dlogits)
    db = dlogits
    dh = classifier.W @ dlogits

    classifier.W -= lr * dW
    classifier.b -= lr * db

    # 🔥 dôležité: rozšírený gradient (nie len posledný token)
    dout = np.zeros_like(out)
    dout[-1] = dh / out.shape[0]

    d_emb = transformer.backward(dout, cache, lr=lr)

    for i, idx in enumerate(x):
        embedding.E[idx] -= lr * d_emb[i]

    return loss

🔥 4. predict_next_transformer (FIX random → stabilita)

def predict_next_transformer(embedding, transformer, classifier, text, word2idx, idx2word):
    x = encode_oov(tokenize(text), word2idx)

    emb = embedding.forward(x)
    out, _ = transformer.forward(emb)

    h = out[-1]

    logits = h @ classifier.W + classifier.b
    probs = softmax(logits)

    # GREEDY + temperature (nie random chaos)
    temperature = 0.7
    probs = np.log(probs + 1e-9) / temperature
    probs = np.exp(probs - np.max(probs))
    probs /= np.sum(probs)

    idx = np.argmax(probs)

    return idx2word[idx]

🔥 5. generate_transformer (stabilnejšia generácia)

def generate_transformer(embedding, transformer, classifier, text, word2idx, idx2word, max_len=10):
    words = tokenize(text)

    for _ in range(max_len):
        next_word = predict_next_transformer(
            embedding,
            transformer,
            classifier,
            " ".join(words),
            word2idx,
            idx2word
        )
        words.append(next_word)

    return " ".join(words)

