def predict_next(embedding, transformer, classifier,
                 text, word2idx, idx2word):

    x = encode_oov(tokenize(text), word2idx)

    emb = embedding.forward(x)

    out = transformer.forward(emb)

    h = out[-1]

    probs = classifier.forward(h)

    idx = np.random.choice(len(probs), p=probs)

    return idx2word[idx]

