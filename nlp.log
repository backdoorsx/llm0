Perfektne, ideme teda krok za krokom prerobiť tvoj kód na skutočný mini-transformer, kde sa gradienty správne počítajú a Q/K/V sa učia. 💪

Zameriame sa na malý, trénovateľný model, ktorý dokáže robiť next-word predikciu. Budeme používať čisto NumPy, aby sme videli, čo sa deje “pod kapotou”, a zároveň udržíme architektúru jednoduchú.
1️⃣ MiniTransformer s gradientom

Najprv definujeme transformer s jednou self-attention vrstvou + mean pooling, ktorý sa dá trénovať:

import numpy as np

class MiniTransformerTrainable:
    def __init__(self, dim):
        self.dim = dim
        # Q, K, V váhy
        self.Wq = np.random.randn(dim, dim) * 0.01
        self.Wk = np.random.randn(dim, dim) * 0.01
        self.Wv = np.random.randn(dim, dim) * 0.01

    def softmax(self, x):
        x = x - np.max(x, axis=-1, keepdims=True)
        exp = np.exp(x)
        return exp / np.sum(exp, axis=-1, keepdims=True)

    def forward(self, x):
        """
        x: (n_words, dim)
        returns: out, cache
        """
        Q = x @ self.Wq       # (n_words, dim)
        K = x @ self.Wk
        V = x @ self.Wv

        scores = Q @ K.T / np.sqrt(self.dim)   # (n_words, n_words)
        attn = self.softmax(scores)            # (n_words, n_words)
        out = attn @ V                         # (n_words, dim)

        cache = (x, Q, K, V, attn)
        return out, cache

    def backward(self, dout, cache, lr=0.01):
        """
        dout: gradient zo zvyšku siete (n_words, dim)
        cache: tuple z forward
        """
        x, Q, K, V, attn = cache
        n = x.shape[0]

        # gradient z out = attn @ V
        dV = attn.T @ dout                      # (dim, dim)
        datt = dout @ V.T                        # (n_words, n_words)

        # softmax backward
        dscores = np.zeros_like(datt)
        for i in range(n):
            a = attn[i][:, None]                 # (n,1)
            da = datt[i][:, None]                # (n,1)
            dscores[i] = (np.diagflat(a) - a @ a.T) @ da[:, 0]

        # scores = Q @ K.T / sqrt(dim)
        dQ = dscores @ K / np.sqrt(self.dim)
        dK = dscores.T @ Q / np.sqrt(self.dim)

        # gradient w.r.t. weights
        dWq = x.T @ dQ
        dWk = x.T @ dK
        dWv = x.T @ dV

        # update
        self.Wq -= lr * dWq
        self.Wk -= lr * dWk
        self.Wv -= lr * dWv

        # gradient pre input x
        dx = dQ @ self.Wq.T + dK @ self.Wk.T + dV @ self.Wv.T
        return dx

✅ Toto už umožňuje skutočný gradient flow cez transformer.
2️⃣ Train-step s transformerom

def train_step_transformer(embedding, transformer, classifier, x, y_idx, lr):
    # embedding
    emb = embedding.forward(x)  # (n_words, dim)

    # transformer forward
    out, cache = transformer.forward(emb)

    # použijeme posledný token ako sentence rep
    h = out[-1]  # (dim,)

    # classifier forward
    logits = h @ classifier.W + classifier.b
    probs = np.exp(logits - np.max(logits))
    probs /= np.sum(probs)

    # loss
    loss = -np.log(probs[y_idx] + 1e-9)

    # backward classifier
    dlogits = probs.copy()
    dlogits[y_idx] -= 1
    dW = np.outer(h, dlogits)
    db = dlogits
    dh = classifier.W @ dlogits

    classifier.W -= lr * dW
    classifier.b -= lr * db

    # backward transformer
    dout = np.zeros_like(out)
    dout[-1] = dh  # gradient len pre posledný token
    d_emb = transformer.backward(dout, cache, lr=lr)

    # backward embedding
    for i, idx in enumerate(x):
        embedding.E[idx] -= lr * d_emb[i]

    return loss

3️⃣ Mini-train loop

def train_lm_transformer(embedding, transformer, classifier, pairs, epochs=200, lr=0.01):
    for epoch in range(epochs):
        total_loss = 0
        for x, y in pairs:
            loss = train_step_transformer(embedding, transformer, classifier, x, y, lr)
            total_loss += loss
        if epoch % 10 == 0:
            print(f"Epoch {epoch}, Loss: {total_loss/len(pairs):.4f}")

4️⃣ Generácia textu

def predict_next_transformer(embedding, transformer, classifier, text, word2idx, idx2word):
    x = encode_oov(tokenize(text), word2idx)
    emb = embedding.forward(x)
    out, _ = transformer.forward(emb)
    h = out[-1]
    logits = h @ classifier.W + classifier.b
    probs = softmax(logits)
    idx = np.random.choice(len(probs), p=probs)
    return idx2word[idx]

def generate_transformer(embedding, transformer, classifier, text, word2idx, idx2word, max_len=10):
    words = tokenize(text)
    for _ in range(max_len):
        next_word = predict_next_transformer(embedding, transformer, classifier, " ".join(words), word2idx, idx2word)
        words.append(next_word)
    return " ".join(words)

💡 Tento setup:

    Transformér sa učí cez backprop

    Classifier a embedding sa učia spoločne

    Dá sa postupne vylepšovať – pridať layer norm, causal mask, multi-head attention

