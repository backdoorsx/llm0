class MiniTransformer:
    def __init__(self, dim):
        self.dim = dim

        self.Wq = np.random.randn(dim, dim) * 0.02
        self.Wk = np.random.randn(dim, dim) * 0.02
        self.Wv = np.random.randn(dim, dim) * 0.02
        self.Wo = np.random.randn(dim, dim) * 0.02   # 🔥 output projection

    def softmax(self, x):
        x = x - np.max(x)
        exp = np.exp(x)
        return exp / np.sum(exp)

    def forward(self, x):
        """
        x: (seq_len, dim)
        """

        pos = np.arange(x.shape[0])[:, None]
        x = x + pos * 0.01

        Q = x @ self.Wq
        K = x @ self.Wk
        V = x @ self.Wv

        scores = Q @ K.T / np.sqrt(self.dim)

        # causal mask
        n = scores.shape[0]
        mask = np.triu(np.ones((n, n)), k=1)
        scores = scores - 1e9 * mask

        attn = np.zeros_like(scores)

        for i in range(n):
            attn[i] = self.softmax(scores[i])

        out = attn @ V

        # projection
        out = out @ self.Wo

        return out, attn

