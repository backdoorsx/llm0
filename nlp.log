def train_step(embedding, transformer, classifier, x, y_idx, lr, idx2word, debug=False):
    """
    Jeden training step language modelu.
    """

    # =========================
    # DEBUG
    # =========================

    if debug:
        print("\n==============================")
        print("INPUT IDS:", x)
        print("INPUT WORDS:", [idx2word[i] for i in x])

    # =========================
    # EMBEDDINGS
    # =========================

    emb = embedding.forward(x)

    if debug:
        print("\nEMBEDDINGS SHAPE:", emb.shape)
        print("EMBEDDINGS SAMPLE:", emb[0])

    # =========================
    # TRANSFORMER
    # =========================

    out = transformer.forward(emb)
    h = out[-1]

    if debug:
        print("\nSENTENCE VECTOR:", h)

    # =========================
    # CLASSIFIER FORWARD
    # =========================

    logits = h @ classifier.W + classifier.b

    probs = np.exp(logits - np.max(logits))
    probs = probs / np.sum(probs)

    if debug:
        print("\nLOGITS:", logits)
        print("\nPROBS TOP 5:")

        top5 = np.argsort(probs)[-5:][::-1]
        for i in top5:
            print(f"{idx2word[i]}: {probs[i]:.4f}")

    # =========================
    # LOSS
    # =========================

    loss = -np.log(probs[y_idx] + 1e-9)

    if debug:
        print("\nTARGET:", y_idx, idx2word[y_idx])
        print("LOSS:", loss)

    # ==================================
    # GRADIENT (softmax + cross entropy)
    # ==================================

    dlogits = probs.copy()
    dlogits[y_idx] -= 1

    # ==================================
    # BACKPROP CLASSIFIER
    # ==================================

    dW = np.outer(h, dlogits)
    db = dlogits

    dh = classifier.W @ dlogits

    classifier.W -= lr * dW
    classifier.b -= lr * db

    # ==================================
    # BACKPROP TRANSFORMER (simplified)
    # ==================================

    v_input = emb[-1]

    dWv = np.outer(v_input, dh)

    transformer.Wv -= lr * dWv

    # ==================================
    # BACKPROP EMBEDDING
    # ==================================

    embedding.update(x, dh / len(x), lr)

    return loss

Čo si tým reálne opravil:

    ❌ chýbajúci dlogits

    ❌ nefunkčný backprop

    ❌ transformer nemal žiadny gradient signál

    ✅ teraz sa učí classifier + embedding + Wv

