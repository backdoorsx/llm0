            self.E[idx] -= lr * grad[i]

✔️ toto je OK minimum
2. PRIDAJ positional encoding (chýba ti úplne)

class PositionalEncoding:
    def __init__(self, dim):
        self.dim = dim

    def forward(self, x):
        pos = np.arange(len(x))[:, None]
        return x + pos / 1000.0

3. MINI TRANSFORMER (OPRAVENÝ)

Tvoj current transformer je „toy“, ale OK základ.

Uprav ho na:

class MiniTransformer:
    def __init__(self, dim):
        self.dim = dim

        self.Wq = np.random.randn(dim, dim) * 0.01
        self.Wk = np.random.randn(dim, dim) * 0.01
        self.Wv = np.random.randn(dim, dim) * 0.01

        # output projection (CHÝBA TI)
        self.Wo = np.random.randn(dim, dim) * 0.01

    def softmax(self, x):
        x = x - np.max(x)
        return np.exp(x) / np.sum(np.exp(x))

    def forward(self, x):
        Q = x @ self.Wq
        K = x @ self.Wk
        V = x @ self.Wv

        scores = Q @ K.T / np.sqrt(self.dim)

        mask = np.triu(np.ones(scores.shape), 1)
        scores = scores - 1e9 * mask

        attn = np.zeros_like(scores)
        for i in range(len(scores)):
            attn[i] = self.softmax(scores[i])

        out = attn @ V

        return out @ self.Wo, attn

4. 🔥 NAJDÔLEŽITEJŠIA ZMENA: LM HEAD (toto ti chýbalo úplne)

Zahoď SimpleClassifierLLM.

Nahradiť:

logits = h @ W_vocab.T

alebo:

class LMHead:
    def __init__(self, dim, vocab):
        self.W = np.random.randn(dim, vocab) * 0.01
        self.b = np.zeros(vocab)

    def forward(self, h):
        return h @ self.W + self.b

