class SimpleClassifierLLM:
    """
    Jednoduchy classifier nad sentence embeddingom.

    Architektura:
        sentence_vector → linear layer → softmax → predikcia slova

    Matematika:
        logits = hW + b
        softmax(logits)
    """

    def __init__(self, embed_dim, vocab_size):
        """
        Inicializacia vah.

        Vstup:
            embed_dim (int): dimenzia sentence vectoru
            vocab_size (int): pocet slov
        """

        self.W = np.random.randn(embed_dim, vocab_size) * 0.01
        self.b = np.zeros(vocab_size)

    def forward(self, h):
        """
        Dopredny vypocet.

        Vstup:
            h (np.array): sentence vector (embed_dim,)

        Vystup:
            probs (np.array): pravdepodobnosti slov

        Matematika:
            logits = hW + b
            softmax(logits)
        """

        logits = h @ self.W + self.b

        exp = np.exp(logits - np.max(logits))
        probs = exp / np.sum(exp)

        return probs

📉 2. Loss funkcia

def cross_entropy(probs, target_idx):
    """
    Cross-entropy loss.

    Vstup:
        probs (np.array): pravdepodobnosti
        target_idx (int): spravne slovo

    Vystup:
        float: strata

    Matematika:
        L = -log(p(target))
    """

    return -np.log(probs[target_idx] + 1e-9)

🔙 3. Backprop (classifier časť)

def backward_classifier(model, h, probs, target_idx, lr):
    """
    Spatne sirenie chyby pre linear layer.

    Vstup:
        model: classifier
        h: sentence vector
        probs: softmax vystup
        target_idx: spravne slovo
        lr: learning rate

    Matematika:
        dL/dlogits = probs - one_hot(target)
    """

    dlogits = probs.copy()
    dlogits[target_idx] -= 1

    dW = np.outer(h, dlogits)
    db = dlogits

    dh = model.W @ dlogits

    model.W -= lr * dW
    model.b -= lr * db

    return dh

🔗 4. Spojenie s embedding + mean pooling

def train_step(embedding, classifier, x, y_idx, lr):
    """
    Jeden training krok.

    Kroky:
        1. embedding lookup
        2. mean pooling
        3. forward classifier
        4. loss
        5. backprop
    """

    emb = embedding.forward(x)

    # sentence representation
    h = mean_pooling(emb)

    # forward
    probs = classifier.forward(h)

    loss = cross_entropy(probs, y_idx)

    # backprop classifier
    dh = backward_classifier(classifier, h, probs, y_idx, lr)

    # backprop embedding (jednoducho rozdelíme gradient)
    grad_emb = dh / len(x)

    embedding.update(x, grad_emb, lr)

    return loss

🔁 5. Tréning loop

def train(model_embed, model_clf, data, word2idx, epochs=300, lr=0.05):
    """
    Trenuje cely model.

    Vstup:
        model_embed: embedding vrstva
        model_clf: classifier
        data: dataset
        word2idx: slovnik
        epochs: pocet iteracii
    """

    for epoch in range(epochs):
        total_loss = 0

        for inp, out in data:
            x = encode_oov(tokenize(inp), word2idx)
            y = encode_oov(tokenize(out), word2idx)[0]

            loss = train_step(model_embed, model_clf, x, y, lr)
            total_loss += loss

        if epoch % 50 == 0:
            print(f"epoch {epoch}, loss {total_loss:.4f}")

💬 6. Predikcia

def predict(embedding, classifier, text, word2idx, idx2word):
    """
    Predikcia jedneho slova.

    Vstup:
        text (str): vstup
    Vystup:
        str: predikovane slovo
    """

    x = encode_oov(tokenize(text), word2idx)

    emb = embedding.forward(x)
    h = mean_pooling(emb)

    probs = classifier.forward(h)

    idx = np.argmax(probs)

    return idx2word[idx]

🚀 7. Použitie

data = load_dataset("datasetllm.json")

word2idx, idx2word = build_vocab(data)

embedding = Embedding(len(word2idx), embed_dim=16)
classifier = SimpleClassifierLLM(embed_dim=16, vocab_size=len(word2idx))

train(embedding, classifier, data, word2idx)

print(predict(embedding, classifier, "ahoj ako sa mas", word2idx, idx2word))

