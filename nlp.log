✅ OPRAVENÁ train_step (FULL)

def train_step(embedding, transformer, classifier, x, y_idx, lr, idx2word, debug=False):
    """
    One training step (fixed shape-safe version).
    """

    emb = embedding.forward(x)

    out = transformer.forward(emb)

    h = out[-1]

    # FORCE 1D VECTOR (KRITICKÉ)
    h = np.asarray(h).reshape(-1)

    if h.shape[0] != classifier.W.shape[0]:
        raise ValueError(f"Shape mismatch: h={h.shape}, W={classifier.W.shape}")

    logits = h @ classifier.W + classifier.b

    probs = np.exp(logits - np.max(logits))
    probs = probs / np.sum(probs)

    loss = -np.log(probs[y_idx] + 1e-9)

    # gradient
    dlogits = probs.copy()
    dlogits[y_idx] -= 1

    # classifier backprop
    dW = np.outer(h, dlogits)
    db = dlogits
    dh = classifier.W @ dlogits

    classifier.W -= lr * dW
    classifier.b -= lr * db

    # embedding update (simple)
    embedding.update(x, np.mean(dh) * np.ones_like(embedding.E[x]), lr)

    return loss

