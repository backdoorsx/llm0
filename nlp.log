import numpy as np
import json
from collections import Counter

# ---------------------------
# DATASET
# ---------------------------
def load_dataset(path):
    with open(path, "r", encoding="utf-8") as f:
        raw = json.load(f)

    data = []
    for item in raw:
        if isinstance(item, dict) and "text" in item:
            data.append(item["text"])
        elif isinstance(item, str):
            data.append(item)

    return data

# ---------------------------
# TOKENIZATION
# ---------------------------
def tokenize(text):
    return text.lower().split()

def encode_oov(tokens, word2idx):
    unk = word2idx["<UNK>"]
    return [word2idx.get(t, unk) for t in tokens]

# ---------------------------
# VOCAB
# ---------------------------
def build_vocab(data, min_freq=1):
    counter = Counter()

    for text in data:
        counter.update(tokenize(text))

    vocab = ["<PAD>", "<UNK>"]
    vocab += [w for w, f in counter.items() if f >= min_freq]

    word2idx = {w: i for i, w in enumerate(vocab)}
    idx2word = {i: w for w, i in word2idx.items()}

    return word2idx, idx2word

# ---------------------------
# DATASET (NEXT TOKEN)
# ---------------------------
def build_language_dataset(data, word2idx):
    pairs = []

    for text in data:
        tokens = tokenize(text)
        encoded = encode_oov(tokens, word2idx)

        for i in range(1, len(encoded)):
            pairs.append((encoded[:i], encoded[i]))

    return pairs

# ---------------------------
# EMBEDDING
# ---------------------------
class Embedding:
    def __init__(self, vocab_size, dim):
        self.E = np.random.randn(vocab_size, dim) * 0.01

    def forward(self, x):
        return self.E[x]

# ---------------------------
# TRANSFORMER (simple causal self-attention)
# ---------------------------
class MiniTransformerBlock:
    def __init__(self, dim):
        self.dim = dim
        self.Wq = np.random.randn(dim, dim) * 0.01
        self.Wk = np.random.randn(dim, dim) * 0.01
        self.Wv = np.random.randn(dim, dim) * 0.01

    def softmax(self, x):
        x = x - np.max(x, axis=-1, keepdims=True)
        e = np.exp(x)
        return e / np.sum(e, axis=-1, keepdims=True)

    def forward(self, x):
        Q = x @ self.Wq
        K = x @ self.Wk
        V = x @ self.Wv

        scores = (Q @ K.T) / np.sqrt(self.dim)

        # causal mask
        n = scores.shape[0]
        mask = np.triu(np.ones((n, n)), k=1) * 1e9
        scores = scores - mask

        attn = self.softmax(scores)
        out = attn @ V

        return out

# ---------------------------
# CLASSIFIER (LM HEAD)
# ---------------------------
class SimpleClassifier:
    def __init__(self, dim, vocab_size):
        self.W = np.random.randn(dim, vocab_size) * 0.01
        self.b = np.zeros(vocab_size)

    def forward(self, h):
        logits = h @ self.W + self.b
        e = np.exp(logits - np.max(logits))
        return e / np.sum(e)

# ---------------------------
# TRAIN STEP
# ---------------------------
def train_step(embedding, transformer, classifier, x, y, lr):
    emb = embedding.forward(x)
    out = transformer.forward(emb)

    h = out[-1]
    probs = classifier.forward(h)

    loss = -np.log(probs[y] + 1e-9)

    # gradient (simple)
    dlogits = probs.copy()
    dlogits[y] -= 1

    dW = np.outer(h, dlogits)
    db = dlogits

    classifier.W -= lr * dW
    classifier.b -= lr * db

    dh = classifier.W @ dlogits

    # backprop do embedding (hrubé ale funkčné)
    for i, idx in enumerate(x):
        embedding.E[idx] -= lr * dh / len(x)

    return loss

# ---------------------------
# TRAIN LOOP
# ---------------------------
def train(embedding, transformer, classifier, pairs, epochs=100, lr=0.01):
    for epoch in range(epochs):
        total = 0

        for x, y in pairs:
            total += train_step(embedding, transformer, classifier, x, y, lr)

        if epoch % 10 == 0:
            print(f"Epoch {epoch}, loss={total/len(pairs):.4f}")

# ---------------------------
# GENERATION
# ---------------------------
def softmax(x):
    x = x - np.max(x)
    e = np.exp(x)
    return e / np.sum(e)

def sample(probs):
    return np.random.choice(len(probs), p=probs)

def generate(embedding, transformer, classifier, text, word2idx, idx2word, max_len=10):
    words = tokenize(text)

    for _ in range(max_len):
        x = encode_oov(words, word2idx)

        emb = embedding.forward(x)
        out = transformer.forward(emb)

        h = out[-1]
        probs = classifier.forward(h)

        idx = sample(probs)
        words.append(idx2word[idx])

    return " ".join(words)

# ---------------------------
# MAIN
# ---------------------------
if __name__ == "__main__":

    data = load_dataset("datasetllm2.json")

    word2idx, idx2word = build_vocab(data)

    pairs = build_language_dataset(data, word2idx)

    embedding = Embedding(len(word2idx), 16)
    transformer = MiniTransformerBlock(16)
    classifier = SimpleClassifier(16, len(word2idx))

    train(embedding, transformer, classifier, pairs, epochs=100, lr=0.01)

    print(generate(
        embedding,
        transformer,
        classifier,
        "ahoj ako",
        word2idx,
        idx2word,
        max_len=10
    ))

