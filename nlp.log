def predict_next_probs_transformer(embedding, transformer, classifier, text, word2idx):
    x = encode_oov(tokenize(text), word2idx)
    emb = embedding.forward(x)
    out, _ = transformer.forward(emb)
    h = out[-1]
    logits = h @ classifier.W + classifier.b
    return softmax(logits)

def sample_top_k(probs, temperature=0.8, top_k=10):
    probs = np.log(probs + 1e-9) / temperature
    probs = np.exp(probs)
    probs = probs / np.sum(probs)

    top_idx = np.argsort(probs)[-top_k:]
    top_probs = probs[top_idx]
    top_probs = top_probs / np.sum(top_probs)

    return np.random.choice(top_idx, p=top_probs)

✅ 2. OPRAVENÝ generate (čistý riadok štýl ako chceš)

def generate_transformer(embedding, transformer, classifier, text, word2idx, idx2word, max_len=10):
    words = tokenize(text)

    for _ in range(max_len):
        probs = predict_next_probs_transformer(embedding, transformer, classifier, " ".join(words), word2idx)
        idx = sample_top_k(probs, temperature=0.8, top_k=10)
        words.append(idx2word[idx])

    return " ".join(words)

