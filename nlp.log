CELÁ LEPŠIA predict_next

def predict_next(
    embedding,
    transformer,
    classifier,
    text,
    word2idx,
    idx2word,
    temperature=0.8
):

    x = encode_oov(tokenize(text), word2idx)

    emb = embedding.forward(x)

    out = transformer.forward(emb)

    h = out[-1]

    logits = h @ classifier.W + classifier.b

    # temperature scaling
    logits = logits / temperature

    probs = np.exp(logits - np.max(logits))
    probs = probs / np.sum(probs)

    idx = np.random.choice(len(probs), p=probs)

    return idx2word[idx]

