    """

    return text.lower().split()

def build_vocab(data, min_freq=1):
    """
    Vytvori slovnik slov s OOV tokenom.

    Vstup:
        data: dataset (input, output)
        min_freq: minimalna frekvencia slova

    Vystup:
        word2idx, idx2word

    Specialne tokeny:
        <PAD> - padding (budeme potrebovat neskor)
        <UNK> - neznama hodnota
    """

    counter = Counter()

    for inp, out in data:
        counter.update(tokenize(inp))
        counter.update(tokenize(out))

    vocab = ["<PAD>", "<UNK>"]

    for word, freq in counter.items():
        if freq >= min_freq:
            vocab.append(word)

    word2idx = {w: i for i, w in enumerate(vocab)}
    idx2word = {i: w for w, i in word2idx.items()}

    return word2idx, idx2word

def encode_oov(tokens, word2idx):
    """
    Prevod tokenov na cisla.

    Vstup:
        tokens (list[str])
        word2idx (dict)

    Vystup:
        list[int]

    Logika:
        - ak slovo existuje -> index
        - ak nie -> <UNK>
    """

    unk_id = word2idx["<UNK>"]

    return [
        word2idx.get(token, unk_id)
        for token in tokens
    ]

def decode_debuger(indices, idx2word):
    """
    Prevod indexov spat na text.

    Vstup:
        indices (list[int])

    Vystup:
        str
    """

    return " ".join([idx2word[i] for i in indices])

if 1==1:
    data = load_dataset("datasetllm.json")

    word2idx, idx2word = build_vocab(data)

    text = "ahoj ako sa citis"

    tokens = tokenize(text)
    encoded = encode_oov(tokens, word2idx)

    print("tokens:", tokens)
    print("encoded:", encoded)
    print("decoded:", decode_debuger(encoded, idx2word))

Super, toto je dobrý základ. Teraz presne nad týmto postavíme mean pooling ako reálnu sentence reprezentáciu, aby si konečne videl „ako sa z vety stane vektor“.
🧠 Čo ti chýba v architektúre

Teraz máš:

text → tokenize → encode → embedding lookup

Chýba:

embeddingy → MEAN POOLING → sentence vector

🧱 1. Doplníme mean pooling funkciu

Pridaj toto do kódu:

def mean_pooling(embeddings):
    """
    Vypocita sentence representation pomocou mean pooling.

    Vstup:
        embeddings (np.array): tvar (n_words, embed_dim)

    Vystup:
        np.array: tvar (embed_dim,)

    Matematika:
        h = (1/n) * Σ e_i

    Vysvetlenie:
        Kazde slovo ma svoj embedding.
        Vsetky sa spriemeruju do jedneho vektora,
        ktory reprezentuje celu vetu.
    """

    return np.mean(embeddings, axis=0)

