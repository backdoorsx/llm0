Upraviť train_lm_transformer ? wtf? daj celu funkciu, uz nevladzem sa opakovat

def train_lm_transformer(embedding, transformer, classifier, pairs, epochs=300, lr=0.01):
    for epoch in range(epochs):

        total_loss = 0

        for x, y in pairs:

            # embedding
            emb = embedding.forward(x)

            # transformer
            out, cache = transformer.forward(emb)

            seq_loss = 0
            dh_total = np.zeros_like(out)

            # GPT-style next-token loss cez CELU sekvenciu
            for t in range(len(y)):

                h = out[t]

                logits = h @ classifier.W + classifier.b
                probs = softmax(logits)

                loss = -np.log(probs[y[t]] + 1e-9)
                seq_loss += loss

                # classifier backward
                dlogits = probs.copy()
                dlogits[y[t]] -= 1

                dW = np.outer(h, dlogits)
                db = dlogits

                dh = classifier.W @ dlogits

                classifier.W -= lr * dW
                classifier.b -= lr * db

                dh_total[t] = dh

            # transformer backward
            d_emb = transformer.backward(dh_total, cache, lr)

            # embedding backward
            for i, idx in enumerate(x):
                embedding.E[idx] -= lr * d_emb[i]

            total_loss += seq_loss / len(y)

        avg_loss = total_loss / len(pairs)

        if epoch % 5 == 0:
            print(f"Epoch {epoch}, loss={avg_loss:.4f}")

A TERAZ MUSÍŠ MAŤ AJ SPRÁVNY build_language_dataset:

def build_language_dataset(data, word2idx):
    pairs = []

    for text, _ in data:

        tokens = tokenize(text)

        encoded = encode_oov(tokens, word2idx)

        if len(encoded) < 2:
            continue

        x = encoded[:-1]
        y = encoded[1:]

        pairs.append((x, y))

    return pairs

