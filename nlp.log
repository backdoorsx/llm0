class Embedding:
    """
    Embedding vrstva.

    Uloha:
        Prevod slov (indexov) na vektory.

    Matematika:
        E[i] = vektor pre slovo i

    Parametre:
        vocab_size: pocet slov
        embed_dim: dimenzia vektora
    """

    def __init__(self, vocab_size, embed_dim):
        """
        Inicializacia embedding matice.

        Vstup:
            vocab_size (int)
            embed_dim (int)

        Vystup:
            nic (inicializuje vahy)
        """

        self.vocab_size = vocab_size
        self.embed_dim = embed_dim

        # embedding matica: nahodne male cisla
        self.E = np.random.randn(vocab_size, embed_dim) * 0.01 # x0

    def forward(self, x):
        """
        Forward pass embedding vrstvy.

        Vstup:
            x (list[int]): indexy slov

        Vystup:
            np.array: matica embeddingov (len(x), embed_dim)

        Logika:
            pre kazde slovo vezmeme riadok z matice E
        """

        return self.E[x]

    def update(self, x, grad, lr):
        """
        Update embeddingov (backprop cast).

        Vstup:
            x (list[int]): indexy slov
            grad (np.array): gradient pre embeddingy
            lr (float): learning rate

        Vystup:
            nic (upravi E)

        Matematika:
            E[i] = E[i] - lr * grad[i]
        """

        for i, word_idx in enumerate(x):
            self.E[word_idx] -= lr * grad[i]


class SimpleClassifierLLM:
    """
    Jednoduchy classifier nad sentence embeddingom.

    Architektura:
        sentence_vector → linear layer → softmax → predikcia slova

    Matematika:
        logits = hW + b
        softmax(logits)
    """

    def __init__(self, embed_dim, vocab_size):
        """
        Inicializacia vah.

        Vstup:
            embed_dim (int): dimenzia sentence vectoru
            vocab_size (int): pocet slov
        """

        self.W = np.random.randn(embed_dim, vocab_size) * 0.01 # x0
        self.b = np.zeros(vocab_size)

    def forward(self, h):
        """
        Dopredny vypocet.

        Vstup:
            h (np.array): sentence vector (embed_dim,)

        Vystup:
            probs (np.array): pravdepodobnosti slov

        Matematika:
            logits = hW + b
            softmax(logits)
        """

        logits = h @ self.W + self.b

        exp = np.exp(logits - np.max(logits))
        probs = exp / np.sum(exp)

        return probs


class MiniTransformerTrainable:
    def __init__(self, dim):
        self.dim = dim
        # Q, K, V váhy
        self.Wq = np.random.randn(dim, dim) * 0.01
        self.Wk = np.random.randn(dim, dim) * 0.01
        self.Wv = np.random.randn(dim, dim) * 0.01

    def softmax(self, x):
        x = x - np.max(x, axis=-1, keepdims=True)
        exp = np.exp(x)
        return exp / np.sum(exp, axis=-1, keepdims=True)
    
    def forward(self, x):
        Q = x @ self.Wq
        K = x @ self.Wk
        V = x @ self.Wv

        scores = (Q @ K.T) / np.sqrt(self.dim)

        # causal mask
        n = scores.shape[0]
        mask = np.triu(np.ones((n, n)), k=1)
        scores = scores - 1e9 * mask

        attn = self.softmax(scores)
        out = attn @ V

        cache = (x, Q, K, V, attn)
        return out, cache
    
    def backward(self, dout, cache, lr=0.01):
        x, Q, K, V, attn = cache
        n = x.shape[0]

        dV = attn.T @ dout
        datt = dout @ V.T

        dscores = np.zeros_like(datt)

        for i in range(n):
            a = attn[i][:, None]
            da = datt[i][:, None]
            dscores[i] = (np.diagflat(a) - a @ a.T) @ da[:, 0]

        dQ = dscores @ K / np.sqrt(self.dim)
        dK = dscores.T @ Q / np.sqrt(self.dim)

        dWq = x.T @ dQ
        dWk = x.T @ dK
        dWv = x.T @ dV

        self.Wq -= lr * dWq
        self.Wk -= lr * dWk
        self.Wv -= lr * dWv

        dx = dQ @ self.Wq.T + dK @ self.Wk.T + dV @ self.Wv.T
        return dx
    
def load_dataset_old(path):
    """
    Nacita dataset zo JSON suboru.

    Vstup:
        path (str): cesta k suboru

    Vystup:
        list[tuple]: [(input, output), ...]
    """

    with open(path, "r", encoding="utf-8") as f:
        raw = json.load(f)

    data = []
    for item in raw:
        data.append((item["input"], item["output"]))

    return data

def tokenize(text):
    """
    Rozdeli text na slova.

    Vstup:
        text (str)

    Vystup:
        list[str]
    """
    if not isinstance(text, str):
        raise TypeError(f"tokenize() expected str, got {type(text)} -> {text}")

    return text.lower().split()

def build_vocab(data, min_freq=1):
    counter = Counter()

    for text, _ in data:
        counter.update(tokenize(text))

    vocab = ["<PAD>", "<UNK>"]

    for word, freq in counter.items():
        if freq >= min_freq:
            vocab.append(word)

    word2idx = {w: i for i, w in enumerate(vocab)}
    idx2word = {i: w for w, i in word2idx.items()}

    return word2idx, idx2word

def build_language_dataset(data, word2idx):
    pairs = []

    for text, _ in data:
        tokens = tokenize(text)
        encoded = encode_oov(tokens, word2idx)

        for i in range(1, len(encoded)):
            x = encoded[:i]
            y = encoded[i]
            pairs.append((x, y))

    return pairs

def encode_oov(tokens, word2idx):
    """
    Prevod tokenov na cisla.

    Vstup:
        tokens (list[str])
        word2idx (dict)

    Vystup:
        list[int]

    Logika:
        - ak slovo existuje -> index
        - ak nie -> <UNK>
    """

    unk_id = word2idx["<UNK>"]

    return [
        word2idx.get(token, unk_id)
        for token in tokens
    ]

def decode_debuger(indices, idx2word):
    """
    Prevod indexov spat na text.

    Vstup:
        indices (list[int])

    Vystup:
        str
    """

    return " ".join([idx2word[i] for i in indices])

def mean_pooling(embeddings):
    """
    Vypocita sentence representation pomocou mean pooling.

    Vstup:
        embeddings (np.array): tvar (n_words, embed_dim)

    Vystup:
        np.array: tvar (embed_dim,)

    Matematika:
        h = (1/n) * Σ e_i

    Vysvetlenie:
        Kazde slovo ma svoj embedding.
        Vsetky sa spriemeruju do jedneho vektora,
        ktory reprezentuje celu vetu.
    """

    return np.mean(embeddings, axis=0)

def cross_entropy(probs, target_idx):
    probs = np.exp(logits - np.max(logits))
    probs = probs / np.sum(probs)
    return -np.log(probs[target] + 1e-9), probs

def backward_classifier(model, h, probs, target_idx, lr):
    """
    Spatne sirenie chyby pre linear layer.

    Vstup:
        model: classifier
        h: sentence vector
        probs: softmax vystup
        target_idx: spravne slovo
        lr: learning rate

    Matematika:
        dL/dlogits = probs - one_hot(target)
    """

    dlogits = probs.copy()
    dlogits[target_idx] -= 1

    dW = np.outer(h, dlogits)
    db = dlogits

    dh = model.W @ dlogits

    model.W -= lr * dW
    model.b -= lr * db

    return dh

def train_step_transformer(embedding, transformer, classifier, x, y_idx, lr):
    emb = embedding.forward(x)

    out, cache = transformer.forward(emb)

    # GPT štýl: posledný token = kontext
    h = out[-1]

    logits = h @ classifier.W + classifier.b
    probs = np.exp(logits - np.max(logits))
    probs /= np.sum(probs)

    loss = -np.log(probs[y_idx] + 1e-9)

    dlogits = probs.copy()
    dlogits[y_idx] -= 1

    dW = np.outer(h, dlogits)
    db = dlogits
    dh = classifier.W @ dlogits

    classifier.W -= lr * dW
    classifier.b -= lr * db

    # 🔥 dôležité: rozšírený gradient (nie len posledný token)
    dout = np.zeros_like(out)
    dout[-1] = dh / out.shape[0]

    d_emb = transformer.backward(dout, cache, lr=lr)

    for i, idx in enumerate(x):
        embedding.E[idx] -= lr * d_emb[i]

    return loss

def train_lm_transformer(embedding, transformer, classifier, pairs, epochs=200, lr=0.01):
    for epoch in range(epochs):
        total_loss = 0
        for x, y in pairs:
            loss = train_step_transformer(embedding, transformer, classifier, x, y, lr)
            total_loss += loss
        if epoch % 10 == 0:
            print(f"Epoch {epoch}, Loss: {total_loss/len(pairs):.4f}")
            
    p = np.exp(-(total_loss / len(pairs)))
    print("epoch", epoch, "loss", total_loss / len(pairs), p*100, "%")
    
def predict_next_probs_transformer(embedding, transformer, classifier, text, word2idx):
    x = encode_oov(tokenize(text), word2idx)
    emb = embedding.forward(x)
    out, _ = transformer.forward(emb)
    h = out[-1]
    logits = h @ classifier.W + classifier.b
    return softmax(logits)

def generate_transformer(embedding, transformer, classifier, text, word2idx, idx2word, max_len=10):
    words = tokenize(text)

    for _ in range(max_len):
        probs = predict_next_probs_transformer(embedding, transformer, classifier, " ".join(words), word2idx)
        idx = sample_top_k(probs, temperature=0.8, top_k=10)
        words.append(idx2word[idx])

    return " ".join(words)
def sample_top_k(probs, temperature=0.8, top_k=10):
    probs = np.log(probs + 1e-9) / temperature
    probs = np.exp(probs)
    probs = probs / np.sum(probs)

    top_idx = np.argsort(probs)[-top_k:]
    top_probs = probs[top_idx]
    top_probs = top_probs / np.sum(top_probs)

    return np.random.choice(top_idx, p=top_probs)

def build_language_dataset_in_out(data, word2idx):
    pairs = []

    for inp, out in data:
        tokens = tokenize(inp) + tokenize(out)

        encoded = encode_oov(tokens, word2idx)

        for i in range(1, len(encoded)):
            x = encoded[:i]      # vstup
            y = encoded[i]      # next word
            pairs.append((x, y))

    return pairs

def build_language_dataset(data, word2idx):
    pairs = []

    for item in data:
        tokens = tokenize(item["text"])
        encoded = encode_oov(tokens, word2idx)

        for i in range(1, len(encoded)):
            x = encoded[:i]
            y = encoded[i]
            pairs.append((x, y))

    return pairs

def load_dataset(path):
    with open(path, "r", encoding="utf-8") as f:
        raw = json.load(f)

    data = [(item["text"], None) for item in raw]
    return data

def softmax(x):
    x = x - np.max(x)
    e = np.exp(x)
    return e / np.sum(e)

def attention(embeddings):
    """
    embeddings: (n_words, dim)
    """

    dim = embeddings.shape[1]

    # 1. query (jednoduchá verzia = priemer alebo posledné slovo)
    q = np.mean(embeddings, axis=0)

    # 2. score pre každé slovo
    scores = embeddings @ q   # (n_words,)

    # 3. váhy
    weights = softmax(scores)

    # 4. weighted sum
    h = np.sum(weights[:, None] * embeddings, axis=0)

    return h, weights

def lm_head(h, E):
    """
    h: (dim,)
    E: embedding matrix (vocab_size, dim)
    """
    return h @ E.T

