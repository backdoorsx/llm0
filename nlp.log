def backward_classifier(model, h, probs, target_idx, lr):
    """
    Spatne sirenie chyby pre linear layer.

    Vstup:
        model: classifier
        h: sentence vector
        probs: softmax vystup
        target_idx: spravne slovo
        lr: learning rate

    Matematika:
        dL/dlogits = probs - one_hot(target)
    """

    dlogits = probs.copy()
    dlogits[target_idx] -= 1

    dW = np.outer(h, dlogits)
    db = dlogits

    dh = model.W @ dlogits

    model.W -= lr * dW
    model.b -= lr * db

    return dh

def train_step_transformer(embedding, transformer, classifier, x, y_idx, lr):
    # embedding
    emb = embedding.forward(x)  # (n_words, dim)

    # transformer forward
    out, cache = transformer.forward(emb)

    # použijeme posledný token ako sentence rep
    h = out[-1]  # (dim,)

    # classifier forward
    logits = h @ classifier.W + classifier.b
    probs = np.exp(logits - np.max(logits))
    probs /= np.sum(probs)

    # loss
    loss = -np.log(probs[y_idx] + 1e-9)

    # backward classifier
    dlogits = probs.copy()
    dlogits[y_idx] -= 1
    dW = np.outer(h, dlogits)
    db = dlogits
    dh = classifier.W @ dlogits

    classifier.W -= lr * dW
    classifier.b -= lr * db

    # backward transformer
    dout = np.zeros_like(out)
    dout[-1] = dh  # gradient len pre posledný token
    d_emb = transformer.backward(dout, cache, lr=lr)

    # backward embedding
    for i, idx in enumerate(x):
        embedding.E[idx] -= lr * d_emb[i]

    return loss

def train_lm_transformer(embedding, transformer, classifier, pairs, epochs=200, lr=0.01):
    for epoch in range(epochs):
        total_loss = 0
        for x, y in pairs:
            loss = train_step_transformer(embedding, transformer, classifier, x, y, lr)
            total_loss += loss
        if epoch % 10 == 0:
            print(f"Epoch {epoch}, Loss: {total_loss/len(pairs):.4f}")
            
    p = np.exp(-(total_loss / len(pairs)))
    print("epoch", epoch, "loss", total_loss / len(pairs), p*100, "%")
    
def predict_next_transformer(embedding, transformer, classifier, text, word2idx, idx2word):
    x = encode_oov(tokenize(text), word2idx)
    emb = embedding.forward(x)
    out, _ = transformer.forward(emb)
    h = out[-1]
    logits = h @ classifier.W + classifier.b
    probs = softmax(logits)
    idx = np.random.choice(len(probs), p=probs)
    return idx2word[idx]

def generate_transformer(embedding, transformer, classifier, text, word2idx, idx2word, max_len=10):
    words = tokenize(text)
    for _ in range(max_len):
        next_word = predict_next_transformer(embedding, transformer, classifier, " ".join(words), word2idx, idx2word)
        words.append(next_word)
    return " ".join(words)

def build_language_dataset(data, word2idx):
    pairs = []

    for inp, out in data:
        tokens = tokenize(inp) + tokenize(out)

        encoded = encode_oov(tokens, word2idx)

        for i in range(1, len(encoded)):
            x = encoded[:i]      # vstup
            y = encoded[i]      # next word
            pairs.append((x, y))

    return pairs

def softmax(x):
    x = x - np.max(x)
    e = np.exp(x)
    return e / np.sum(e)

def attention(embeddings):
    """
    embeddings: (n_words, dim)
    """

    dim = embeddings.shape[1]

    # 1. query (jednoduchá verzia = priemer alebo posledné slovo)
    q = np.mean(embeddings, axis=0)

    # 2. score pre každé slovo
    scores = embeddings @ q   # (n_words,)

    # 3. váhy
    weights = softmax(scores)

    # 4. weighted sum
    h = np.sum(weights[:, None] * embeddings, axis=0)

    return h, weights

def lm_head(h, E):
    """
    h: (dim,)
    E: embedding matrix (vocab_size, dim)
    """
    return h @ E.T

