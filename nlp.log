import numpy as np
import json
from collections import Counter

# ---------------------------
# DATASET
# ---------------------------
def load_dataset(path):
    with open(path, "r", encoding="utf-8") as f:
        raw = json.load(f)

    data = []
    for item in raw:
        if isinstance(item, dict) and "text" in item:
            data.append(item["text"])
        elif isinstance(item, str):
            data.append(item)

    return data

# ---------------------------
# TOKENIZATION
# ---------------------------
def tokenize(text):
    return text.lower().split()

def encode(tokens, word2idx):
    unk = word2idx["<UNK>"]
    return [word2idx.get(t, unk) for t in tokens]

# ---------------------------
# VOCAB
# ---------------------------
def build_vocab(data, min_freq=1):
    counter = Counter()
    for text in data:
        counter.update(tokenize(text))

    vocab = ["<PAD>", "<UNK>"] + [w for w, f in counter.items() if f >= min_freq]
    word2idx = {w:i for i,w in enumerate(vocab)}
    idx2word = {i:w for w,i in word2idx.items()}
    return word2idx, idx2word

# ---------------------------
# DATASET (NEXT TOKEN)
# ---------------------------
def build_dataset(data, word2idx):
    pairs = []
    for text in data:
        tokens = tokenize(text)
        enc = encode(tokens, word2idx)

        for i in range(1, len(enc)):
            pairs.append((enc[:i], enc[i]))

    return pairs

# ---------------------------
# EMBEDDING
# ---------------------------
class Embedding:
    def __init__(self, vocab_size, dim):
        self.E = np.random.randn(vocab_size, dim) * 0.02

    def forward(self, x):
        return self.E[x]

# ---------------------------
# LAYER NORM
# ---------------------------
class LayerNorm:
    def __init__(self, dim):
        self.gamma = np.ones(dim)
        self.beta = np.zeros(dim)
        self.eps = 1e-5

    def forward(self, x):
        self.mean = np.mean(x, axis=-1, keepdims=True)
        self.var = np.var(x, axis=-1, keepdims=True)
        self.x_norm = (x - self.mean) / np.sqrt(self.var + self.eps)
        return self.gamma * self.x_norm + self.beta

# ---------------------------
# TRANSFORMER BLOCK
# ---------------------------
class MiniTransformer:
    def __init__(self, dim):
        self.dim = dim
        self.Wq = np.random.randn(dim, dim) * 0.01
        self.Wk = np.random.randn(dim, dim) * 0.01
        self.Wv = np.random.randn(dim, dim) * 0.01

        self.ln1 = LayerNorm(dim)

    def softmax(self, x):
        x = x - np.max(x, axis=-1, keepdims=True)
        e = np.exp(x)
        return e / np.sum(e, axis=-1, keepdims=True)

    def forward(self, x):
        Q = x @ self.Wq
        K = x @ self.Wk
        V = x @ self.Wv

        scores = Q @ K.T / np.sqrt(self.dim)

        # causal mask
        n = scores.shape[0]
        mask = np.triu(np.ones((n, n)), k=1) * 1e9
        scores = scores - mask

        attn = self.softmax(scores)
        out = attn @ V

        x = self.ln1.forward(x + out)

        return x

# ---------------------------
# CLASSIFIER
# ---------------------------
class LMHead:
    def __init__(self, dim, vocab_size):
        self.W = np.random.randn(dim, vocab_size) * 0.01
        self.b = np.zeros(vocab_size)

    def forward(self, h):
        logits = h @ self.W + self.b
        e = np.exp(logits - np.max(logits))
        return e / np.sum(e)

# ---------------------------
# LOSS + TRAIN STEP
# ---------------------------
def train_step(embed, model, head, x, y, lr):
    emb = embed.forward(x)
    out = model.forward(emb)

    h = out[-1]
    probs = head.forward(h)

    loss = -np.log(probs[y] + 1e-9)

    dlog = probs.copy()
    dlog[y] -= 1

    head.W -= lr * np.outer(h, dlog)
    head.b -= lr * dlog

    dh = head.W @ dlog

    for i, idx in enumerate(x):
        embed.E[idx] -= lr * dh / len(x)

    return loss

# ---------------------------
# TRAIN LOOP (batch)
# ---------------------------
def train(embed, model, head, pairs, epochs=50, lr=0.01, batch_size=16):
    for epoch in range(epochs):
        np.random.shuffle(pairs)
        total = 0

        for i in range(0, len(pairs), batch_size):
            batch = pairs[i:i+batch_size]

            for x, y in batch:
                total += train_step(embed, model, head, x, y, lr)

        if epoch % 5 == 0:
            print(f"Epoch {epoch}, loss={total/len(pairs):.4f}")

# ---------------------------
# SAMPLING (TOP-K + TEMP)
# ---------------------------
def sample(probs, top_k=5, temperature=0.8):
    probs = np.log(probs + 1e-9) / temperature
    probs = np.exp(probs)
    probs = probs / np.sum(probs)

    idxs = np.argsort(probs)[-top_k:]
    p = probs[idxs]
    p = p / np.sum(p)

    return np.random.choice(idxs, p=p)

# ---------------------------
# GENERATION
# ---------------------------
def generate(embed, model, head, text, word2idx, idx2word, max_len=10):
    words = tokenize(text)

    for _ in range(max_len):
        x = encode(words, word2idx)

        emb = embed.forward(x)
        out = model.forward(emb)

        h = out[-1]
        probs = head.forward(h)

        idx = sample(probs, top_k=5, temperature=0.8)
        words.append(idx2word[idx])

    return " ".join(words)

# ---------------------------
# MAIN
# ---------------------------
if __name__ == "__main__":

    data = load_dataset("datasetllm2.json")

    word2idx, idx2word = build_vocab(data)

    pairs = build_dataset(data, word2idx)

    embed = Embedding(len(word2idx), 64)
    model = MiniTransformer(64)
    head = LMHead(64, len(word2idx))

    train(embed, model, head, pairs, epochs=50, lr=0.01)

    print(generate(
        embed,
        model,
        head,
        "ahoj ako",
        word2idx,
        idx2word,
        max_len=10
    ))

