CELÁ OPRAVENÁ FUNKCIA train_step

def train_step(
    embedding,
    transformer,
    classifier,
    x,
    y_idx,
    lr,
    idx2word,
    debug=False
):
    """
    Jeden training step language modelu.
    """

    # =========================
    # DEBUG
    # =========================

    if debug:
        print("\n==============================")
        print("INPUT IDS:", x)
        print("INPUT WORDS:", [idx2word[i] for i in x])

    # =========================
    # EMBEDDINGS
    # =========================

    emb = embedding.forward(x)

    if debug:
        print("\nEMBEDDINGS SHAPE:", emb.shape)
        print("EMBEDDINGS SAMPLE:", emb[0])

    # =========================
    # TRANSFORMER
    # =========================

    out = transformer.forward(emb)

    # reprezentacia posledneho tokenu
    h = out[-1]

    if debug:
        print("\nSENTENCE VECTOR:", h)

    # =========================
    # CLASSIFIER
    # =========================

    logits = h @ classifier.W + classifier.b

    probs = np.exp(logits - np.max(logits))
    probs = probs / np.sum(probs)

    if debug:
        print("\nLOGITS:", logits)

        print("\nPROBS TOP 5:")

        top5 = np.argsort(probs)[-5:][::-1]

        for i in top5:
            print(f"{idx2word[i]}: {probs[i]:.4f}")

    # =========================
    # LOSS
    # =========================

    loss = -np.log(probs[y_idx] + 1e-9)

    if debug:
        print("\nTARGET:", y_idx, idx2word[y_idx])
        print("LOSS:", loss)

    # =========================
    # BACKPROP CLASSIFIER
    # =========================

    dlogits = probs.copy()
    dlogits[y_idx] -= 1

    dW = np.outer(h, dlogits)
    db = dlogits

    dh = classifier.W @ dlogits

    classifier.W -= lr * dW
    classifier.b -= lr * db

    # =========================
    # EMBEDDING UPDATE
    # =========================

    # jednoduchá aproximácia gradientu
    grad_emb = np.tile(dh, (len(x), 1)) / len(x)

    embedding.update(x, grad_emb, lr)

    return loss

