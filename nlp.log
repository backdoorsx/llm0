import numpy as np
import matplotlib.pyplot as plt


def f(x, y):
    """
    Non-convex funkcia s viacerými minimami.

    Vstup:
        x, y (float alebo array)

    Vystup:
        float
    """
    return np.sin(x) * np.cos(y) + 0.1 * (x**2 + y**2)


def plot_landscape():
    """
    Vykreslí loss landscape s viacerými minimami.

    Vystup:
