    # transformer
    out = transformer.forward(emb)

    # reprezentacia posledneho tokenu
    h = out[-1]

    # classifier
    probs = classifier.forward(h)

    # najpravdepodobnejsie slovo
    idx = np.argmax(probs)

    return idx2word[idx]

2. POSITIONAL ENCODING

Teraz uprav CELÚ funkciu forward() v MiniTransformer.

Nájdi toto:

def forward(self, x):
    """
    x shape:
        (n_tokens, dim)
    """

    # Q K V
    Q = x @ self.Wq
    K = x @ self.Wk
    V = x @ self.Wv

    # attention scores
    scores = Q @ K.T / np.sqrt(self.dim)

    # causal mask (nevidi buducnost)
    n = scores.shape[0]
    mask = np.triu(np.ones((n, n)), k=1)

    scores = scores - 1e9 * mask

    # softmax row-wise
    attn = np.zeros_like(scores)

    for i in range(n):
        attn[i] = self.softmax(scores[i])

    # weighted sum
    out = attn @ V

    return out

a nahraď CELÚ funkciu týmto:

def forward(self, x):
    """
    x shape:
        (n_tokens, dim)
    """

    # =========================
    # POSITIONAL ENCODING
    # =========================

    positions = np.arange(x.shape[0])[:, None]

    x = x + positions * 0.01

    # =========================
    # Q K V
    # =========================

    Q = x @ self.Wq
    K = x @ self.Wk
    V = x @ self.Wv

    # =========================
    # ATTENTION SCORES
    # =========================

    scores = Q @ K.T / np.sqrt(self.dim)

    # =========================
    # CAUSAL MASK
    # =========================

    n = scores.shape[0]

    mask = np.triu(np.ones((n, n)), k=1)

    scores = scores - 1e9 * mask

    # =========================
    # SOFTMAX
    # =========================

    attn = np.zeros_like(scores)

    for i in range(n):
        attn[i] = self.softmax(scores[i])

    # =========================
    # WEIGHTED SUM
    # =========================

    out = attn @ V

    return out

