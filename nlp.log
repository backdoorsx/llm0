🚀 1. CELÝ FUNKČNÝ MINI TRANSFORMER SYSTEM

Skopíruj toto ako nový súbor (napr. mini_gpt.py)
🔹 IMPORTY + UTILITY

import json
import numpy as np
from collections import Counter

def tokenize(text):
    return text.lower().split()

def softmax(x):
    x = x - np.max(x)
    e = np.exp(x)
    return e / np.sum(e)

🔹 2. DATASET

def load_dataset(path):
    with open(path, "r", encoding="utf-8") as f:
        raw = json.load(f)

    data = []
    for item in raw:
        data.append((item["input"], item["output"]))
    return data

def build_vocab(data):
    c = Counter()
    for a, b in data:
        c.update(tokenize(a))
        c.update(tokenize(b))

    vocab = ["<PAD>", "<UNK>"] + list(c.keys())
    word2idx = {w:i for i,w in enumerate(vocab)}
    idx2word = {i:w for w,i in word2idx.items()}
    return word2idx, idx2word

🔹 3. ENCODING

def encode(text, word2idx):
    unk = word2idx["<UNK>"]
    return [word2idx.get(t, unk) for t in tokenize(text)]

🔹 4. EMBEDDING

class Embedding:
    def __init__(self, vocab_size, dim):
        self.E = np.random.randn(vocab_size, dim) * 0.01

    def forward(self, x):
        return self.E[x]

🔹 5. TRAINABLE TRANSFORMER (REAL BACKPROP)

class MiniTransformer:
    def __init__(self, dim):
        self.dim = dim
        self.Wq = np.random.randn(dim, dim) * 0.01
        self.Wk = np.random.randn(dim, dim) * 0.01
        self.Wv = np.random.randn(dim, dim) * 0.01

    def softmax(self, x):
        x = x - np.max(x, axis=-1, keepdims=True)
        e = np.exp(x)
        return e / np.sum(e, axis=-1, keepdims=True)

    def forward(self, x):
        self.x = x

        self.Q = x @ self.Wq
        self.K = x @ self.Wk
        self.V = x @ self.Wv

        self.scores = self.Q @ self.K.T / np.sqrt(self.dim)
        self.attn = self.softmax(self.scores)
        self.out = self.attn @ self.V

        return self.out

    def backward(self, dout, lr):
        n = self.x.shape[0]

        dV = self.attn.T @ dout
        datt = dout @ self.V.T

        dscores = np.zeros_like(self.scores)

        for i in range(n):
            a = self.attn[i].reshape(-1,1)
            g = datt[i].reshape(-1,1)
            dscores[i] = (np.diagflat(a) - a @ a.T) @ g[:,0]

        dQ = dscores @ self.K / np.sqrt(self.dim)
        dK = dscores.T @ self.Q / np.sqrt(self.dim)

        dWq = self.x.T @ dQ
        dWk = self.x.T @ dK
        dWv = self.x.T @ dV

        self.Wq -= lr * dWq
        self.Wk -= lr * dWk
        self.Wv -= lr * dWv

        dx = dQ @ self.Wq.T + dK @ self.Wk.T + dV @ self.Wv.T
        return dx

🔹 6. CLASSIFIER

class Classifier:
    def __init__(self, dim, vocab):
        self.W = np.random.randn(dim, vocab) * 0.01
        self.b = np.zeros(vocab)

    def forward(self, h):
        logits = h @ self.W + self.b
        exp = np.exp(logits - np.max(logits))
        return exp / np.sum(exp), logits

🔹 7. TRAIN STEP (KĽÚČOVÉ)

def train_step(emb, transformer, clf, x, y, lr):
    x_emb = emb.forward(x)

    out = transformer.forward(x_emb)

    h = out[-1]

    probs, logits = clf.forward(h)

    loss = -np.log(probs[y] + 1e-9)

    # classifier gradient
    dlogits = probs.copy()
    dlogits[y] -= 1

    dW = np.outer(h, dlogits)
    db = dlogits
    dh = clf.W @ dlogits

    clf.W -= lr * dW
    clf.b -= lr * db

    # transformer backward
    dout = np.zeros_like(out)
    dout[-1] = dh

    dx = transformer.backward(dout, lr)

    # embedding update
    for i, idx in enumerate(x):
        emb.E[idx] -= lr * dx[i]

    return loss

🔹 8. TRAIN LOOP

def train(data, epochs=100, lr=0.01, dim=16):
    word2idx, idx2word = build_vocab(data)

    emb = Embedding(len(word2idx), dim)
    trans = MiniTransformer(dim)
    clf = Classifier(dim, len(word2idx))

    pairs = []
    for a, b in data:
        tokens = encode(a + " " + b, word2idx)
        for i in range(1, len(tokens)):
            pairs.append((tokens[:i], tokens[i]))

    for epoch in range(epochs):
        total = 0
        for x, y in pairs:
            total += train_step(emb, trans, clf, x, y, lr)

        if epoch % 10 == 0:
            print("epoch", epoch, "loss", total / len(pairs))

    return emb, trans, clf, word2idx, idx2word

🔹 9. GENERÁCIA

def generate(emb, trans, clf, text, word2idx, idx2word, max_len=10):
    x = encode(text, word2idx)

    words = tokenize(text)

    for _ in range(max_len):
        out = trans.forward(emb.forward(x))
        h = out[-1]

        probs, _ = clf.forward(h)

        idx = np.argmax(probs)

        words.append(idx2word[idx])
        x = encode(" ".join(words), word2idx)

    return " ".join(words)

🔹 10. MAIN

if __name__ == "__main__":
    data = load_dataset("datasetllm.json")

    emb, trans, clf, w2i, i2w = train(
        data,
        epochs=100,
        lr=0.01,
        dim=16
    )

    print(generate(emb, trans, clf, "ahoj ako", w2i, i2w))

