import numpy as np
import matplotlib.pyplot as plt


class GradientDescent2D:
    """
    Simulacia gradient descent v 2D priestore.
    """

    def f(self, x, y):
        """
        Loss funkcia.

        Vstup:
            x, y (float)

        Vystup:
            float
        """
        return x**2 + y**2

    def grad(self, x, y):
        """
        Gradient funkcie.

        Vstup:
            x, y (float)

        Vystup:
            tuple (df/dx, df/dy)
        """
        return 2*x, 2*y

    def run(self, x0, y0, lr=0.1, steps=20):
        """
        Gradient descent simulacia.

        Vstup:
            x0, y0 (float)
            lr (float)
            steps (int)

        Vystup:
            np.array trajektoria
        """

        path = [(x0, y0)]
        x, y = x0, y0

        for _ in range(steps):
            gx, gy = self.grad(x, y)
            x = x - lr * gx
            y = y - lr * gy
            path.append((x, y))

        return np.array(path)


def plot_gradient_descent_2d(path):
    """
    Vykresli 2D gradient descent trajektoriu.

    Vstup:
