def generate_transformer(embedding, transformer, classifier, text, word2idx, idx2word, max_len=10):
    words = tokenize(text)

    for _ in range(max_len):
        probs = predict_next_probs(embedding, transformer, classifier, " ".join(words), word2idx)
        idx = sample(probs, temperature=0.8, top_k=10)
        words.append(idx2word[idx])

    return " ".join(words)

