Kompletný edukačný kód

import numpy as np


# =========================================================
# DATASET
# =========================================================
# Jednoduché konverzačné páry (input → output)

data = [
    ("ahoj", "ahoj"),
    ("ahoj ako sa mas", "mam sa dobre"),
    ("ako sa mas", "mam sa fajn"),
    ("co robis", "rozpravam sa"),
    ("ako sa volas", "som chatbot"),
    ("kolko mas rokov", "nemam vek"),
    ("co je tvoje meno", "som ai"),
    ("ako sa citis", "citim sa dobre"),
    ("co mas rad", "mam rad konverzacie"),
    ("kde byvas", "byvam v cloude"),
    ("co je dnes", "je pekny den"),
    ("co robis teraz", "pisem odpoved"),
    ("rozumies mi", "ano rozumiem"),
    ("co je ai", "umely agent"),
    ("ako fungujes", "pouzivam model"),
    ("co je python", "programovaci jazyk"),
    ("co je matematika", "veda o cislach"),
    ("co je laska", "je to pocit"),
    ("si realny", "som virtualny"),
    ("pomozes mi", "ano pomozem"),
]


# =========================================================
# TOKENIZACIA
# =========================================================
def tokenize(text):
    """
    Rozdeli vstupny text na tokeny (slova).

    Vstup:
        text (str): veta

    Vystup:
        list[str]: zoznam slov

    Priklad:
        "ahoj ako sa mas" -> ["ahoj", "ako", "sa", "mas"]
    """
    return text.lower().split()


# =========================================================
# VOCABULARY
# =========================================================
def build_vocab(data):
    """
    Vytvori slovnik (vocabulary) zo datasetu.

    Vstup:
        data (list[tuple]): zoznam dvojic (input, output)

    Vystup:
        word2idx (dict): mapovanie slovo -> index
        idx2word (dict): mapovanie index -> slovo

    Poznamka:
        Kazde slovo dostane jedinecne cele cislo.
    """
    vocab = set()

    for inp, out in data:
        vocab.update(tokenize(inp))
        vocab.update(tokenize(out))

    word2idx = {w: i for i, w in enumerate(vocab)}
    idx2word = {i: w for w, i in word2idx.items()}

    return word2idx, idx2word


# =========================================================
# ENCODING
# =========================================================
def encode(tokens, word2idx):
    """
    Prevedie zoznam slov na zoznam indexov.

    Vstup:
        tokens (list[str]): slova
        word2idx (dict): mapovanie slovo -> index

    Vystup:
        list[int]: indexy slov

    Priklad:
        ["ahoj", "ako"] -> [3, 7]
    """
    return [word2idx[t] for t in tokens]


# =========================================================
# MODEL
# =========================================================
class SimpleLLM:
    """
    Jednoducha neuronova siet:

    embedding -> priemer -> linear -> softmax

    Parametre:
        embed: (vocab_size x embed_size)
        W: (embed_size x vocab_size)
        b: (vocab_size)

    Matematika:
        h = priemer embeddingov
        logits = hW + b
        probs = softmax(logits)
    """

    def __init__(self, vocab_size, embed_size=16):
        """
        Inicializuje vahy modelu.

        Vstup:
            vocab_size (int): pocet slov v slovniku
            embed_size (int): dimenzia embeddingu
        """
        self.embed = np.random.randn(vocab_size, embed_size) * 0.1
        self.W = np.random.randn(embed_size, vocab_size) * 0.1
        self.b = np.zeros(vocab_size)

    def forward(self, x):
        """
        Dopredny vypocet (forward pass).

        Vstup:
            x (list[int]): indexy slov

        Vystup:
            probs (np.array): pravdepodobnosti pre kazde slovo
            h (np.array): hidden reprezentacia
            emb (np.array): embeddingy vstupnych slov

        Kroky:
            1. vyber embeddingov
            2. spriemerovanie
            3. linearna transformacia
            4. softmax

        Softmax:
            softmax(z_i) = exp(z_i) / sum(exp(z))
        """
        emb = self.embed[x]
        h = np.mean(emb, axis=0)

        logits = h @ self.W + self.b

        exp = np.exp(logits - np.max(logits))
        probs = exp / np.sum(exp)

        return probs, h, emb


# =========================================================
# LOSS
# =========================================================
def loss_fn(probs, target):
    """
    Cross-entropy stratova funkcia.

    Vstup:
        probs (np.array): pravdepodobnosti
        target (int): index spravneho slova

    Vystup:
        float: hodnota straty

    Matematika:
        L = -log(p_target)

    Vysvetlenie:
        Penalizuje model, ak dava nizku pravdepodobnost spravnemu slovu.
    """
    return -np.log(probs[target] + 1e-9)


# =========================================================
# BACKPROP
# =========================================================
def backward(model, x, probs, h, emb, target, lr=0.05):
    """
    Spatne sirenie chyby (backpropagation).

    Vstup:
        model: instancia modelu
        x (list[int]): vstup
        probs (np.array): vystup softmaxu
        h (np.array): hidden vrstva
        emb (np.array): embeddingy
        target (int): spravne slovo
        lr (float): learning rate

    Vystup:
        None (update vah v modeli)

    Matematika:
        dL/dlogits = probs - one_hot(target)

        Pouziva sa gradient descent:
        W = W - lr * dW
    """

    dlogits = probs.copy()
    dlogits[target] -= 1

    dW = np.outer(h, dlogits)
    db = dlogits

    dh = model.W @ dlogits

    demb = dh / len(x)

    for idx in x:
        model.embed[idx] -= lr * demb

    model.W -= lr * dW
    model.b -= lr * db


# =========================================================
# TRAINING
# =========================================================
def train(model, data, word2idx, epochs=500):
    """
    Trenuje model pomocou gradient descent.

    Vstup:
        model: neuronova siet
        data: dataset
        word2idx: slovnik
        epochs (int): pocet iteracii

    Vystup:
        None

    Postup:
        - pre kazdy priklad spravi forward pass
        - vypocita loss
        - spravi backpropagation
    """
    for epoch in range(epochs):
        total_loss = 0

        for inp, out in data:
            x = encode(tokenize(inp), word2idx)
            y = encode(tokenize(out), word2idx)[0]

            probs, h, emb = model.forward(x)
            loss = loss_fn(probs, y)

            backward(model, x, probs, h, emb, y)
            total_loss += loss

        if epoch % 50 == 0:
            print(f"Epoch {epoch}, loss: {total_loss:.4f}")


# =========================================================
# GENEROVANIE
# =========================================================
def generate(model, text, word2idx, idx2word):
    """
    Generuje jedno slovo ako odpoved.

    Vstup:
        model: natrenovana siet
        text (str): vstupna veta
        word2idx: slovnik
        idx2word: reverzny slovnik

    Vystup:
        str: predikovane slovo

    Postup:
        - tokenizacia
        - encoding
        - forward pass
        - vyber slova s najvyssou pravdepodobnostou (argmax)
    """
    tokens = tokenize(text)
    x = encode(tokens, word2idx)

    probs, _, _ = model.forward(x)
    idx = np.argmax(probs)

    return idx2word[idx]


# =========================================================
# SPUSTENIE
# =========================================================
word2idx, idx2word = build_vocab(data)
model = SimpleLLM(len(word2idx))

train(model, data, word2idx)

print(generate(model, "co je dnes", word2idx, idx2word))

Čo je teraz lepšie

    každá funkcia má jasný účel

    máš tam matematiku (derivácia, loss)

