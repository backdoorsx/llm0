    embedding = Embedding(len(word2idx), embed_dim=16)
    classifier = SimpleClassifierLLM(embed_dim=16, vocab_size=len(word2idx))

    train(embedding, classifier, data, word2idx, idx2word)

    print(predict(embedding, classifier, "ahoj ako sa mas", word2idx, idx2word))

