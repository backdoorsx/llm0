data = load_dataset("datasetllm.json")

word2idx, idx2word = build_vocab(data)

text = "ahoj ako sa citis"

tokens = tokenize(text)
encoded = encode(tokens, word2idx)

print("tokens:", tokens)
print("encoded:", encoded)
print("decoded:", decode(encoded, idx2word))

