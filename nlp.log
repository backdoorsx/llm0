def train_step_debug(embedding, classifier, x, y_idx, lr, idx2word):
    """
    Trening krok s detailnym vypisom co sa deje.
    """

    print("\n==============================")
    print("INPUT IDS:", x)
    print("INPUT WORDS:", [idx2word[i] for i in x])

    # 1. embedding
    emb = embedding.forward(x)
    print("\nEMBEDDINGS SHAPE:", emb.shape)
    print("EMBEDDINGS SAMPLE:", emb[0])

    # 2. sentence representation
    h = mean_pooling(emb)
    print("\nSENTENCE VECTOR:", h)

    # 3. forward pass
    logits = h @ classifier.W + classifier.b
    print("\nLOGITS:", logits)

    probs = np.exp(logits - np.max(logits))
    probs = probs / np.sum(probs)

    print("\nPROBS TOP 5:")

    top5 = np.argsort(probs)[-5:][::-1]
    for i in top5:
        print(f"{idx2word[i]}: {probs[i]:.4f}")

    # 4. target
    print("\nTARGET:", y_idx, idx2word[y_idx])

    # 5. loss
    loss = -np.log(probs[y_idx] + 1e-9)
    print("LOSS:", loss)

    # 6. backprop
    dlogits = probs.copy()
    dlogits[y_idx] -= 1

    print("\nGRADIENT SAMPLE:", dlogits[:5])

    # update classifier
    dW = np.outer(h, dlogits)
    db = dlogits
    dh = classifier.W @ dlogits

    classifier.W -= lr * dW
    classifier.b -= lr * db

    embedding.update(x, dh / len(x), lr)

    return loss

🔁 upravený tréning loop

def train_debug(embedding, classifier, data, word2idx, idx2word, epochs=1, lr=0.05):
    """
    Trening s kompletnym vypisom vnutra modelu.
    """

    for epoch in range(epochs):
        print("\n##############################")
        print("EPOCH:", epoch)

        total_loss = 0

        for inp, out in data:
            x = encode_oov(tokenize(inp), word2idx)
            y = encode_oov(tokenize(out), word2idx)[0]

            loss = train_step_debug(embedding, classifier, x, y, lr, idx2word)

            total_loss += loss

        print("\nEPOCH LOSS:", total_loss)

