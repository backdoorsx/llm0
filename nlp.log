def lm_head(h, E):
    """
    h: (dim,)
    E: embedding matrix (vocab_size, dim)
    """
    return h @ E.T

🧠 LOSS (SPRÁVNY NEXT TOKEN)

def cross_entropy(logits, target):
    probs = np.exp(logits - np.max(logits))
    probs = probs / np.sum(probs)
    return -np.log(probs[target] + 1e-9), probs

🚀 TRAIN STEP (ČISTÝ A FUNKČNÝ)

def train_step(embedding, transformer, x, lr):

    emb = embedding.forward(x)         # (seq, dim)

    out, attn = transformer.forward(emb)

    total_loss = 0

    # next-token learning
    for t in range(len(x) - 1):

        h = out[t]   # 🔥 transformer output per token

        logits = h @ embedding.E.T

        loss, probs = cross_entropy(logits, x[t+1])
        total_loss += loss

        # gradient (simple softmax CE)
        dlogits = probs.copy()
        dlogits[x[t+1]] -= 1

        dE = np.outer(dlogits, h)

        embedding.E -= lr * dE.T

        # transformer update (simplified)
        transformer.Wo -= lr * np.outer(attn[t], h) * 0.01

    return total_loss

🔥 GENERATE (SPRÁVNE)

def generate(embedding, transformer, text, word2idx, idx2word, max_len=10):

    x = encode_oov(tokenize(text), word2idx)

    for _ in range(max_len):

        emb = embedding.forward(x)

        out, _ = transformer.forward(emb)

        h = out[-1]

        logits = h @ embedding.E.T

        probs = np.exp(logits - np.max(logits))
        probs = probs / np.sum(probs)

        idx = np.random.choice(len(probs), p=probs)

        x.append(idx)

    return " ".join([idx2word[i] for i in x])

