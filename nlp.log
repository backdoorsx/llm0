neviem to najst: class Embedding:
    """
    Embedding vrstva.

    Uloha:
        Prevod slov (indexov) na vektory.

    Matematika:
        E[i] = vektor pre slovo i

    Parametre:
        vocab_size: pocet slov
        embed_dim: dimenzia vektora
    """

    def __init__(self, vocab_size, embed_dim):
        """
        Inicializacia embedding matice.

        Vstup:
            vocab_size (int)
            embed_dim (int)

        Vystup:
            nic (inicializuje vahy)
        """

        self.vocab_size = vocab_size
        self.embed_dim = embed_dim

        # embedding matica: nahodne male cisla
        self.E = np.random.randn(vocab_size, embed_dim) * 0.01

    def forward(self, x):
        """
        Forward pass embedding vrstvy.

        Vstup:
            x (list[int]): indexy slov

        Vystup:
            np.array: matica embeddingov (len(x), embed_dim)

        Logika:
            pre kazde slovo vezmeme riadok z matice E
        """

        return self.E[x]

    def update(self, x, grad, lr):
        """
        Update embeddingov (backprop cast).

        Vstup:
            x (list[int]): indexy slov
            grad (np.array): gradient pre embeddingy
            lr (float): learning rate

        Vystup:
            nic (upravi E)

        Matematika:
            E[i] = E[i] - lr * grad[i]
        """

        for i, word_idx in enumerate(x):
            self.E[word_idx] -= lr * grad[i]


class SimpleClassifierLLM:
    """
    Jednoduchy classifier nad sentence embeddingom.

    Architektura:
        sentence_vector → linear layer → softmax → predikcia slova

    Matematika:
        logits = hW + b
        softmax(logits)
    """

    def __init__(self, embed_dim, vocab_size):
        """
        Inicializacia vah.

        Vstup:
            embed_dim (int): dimenzia sentence vectoru
            vocab_size (int): pocet slov
        """

        self.W = np.random.randn(embed_dim, vocab_size) * 0.01
        self.b = np.zeros(vocab_size)

    def forward(self, h):
        """
        Dopredny vypocet.

        Vstup:
            h (np.array): sentence vector (embed_dim,)

        Vystup:
            probs (np.array): pravdepodobnosti slov

        Matematika:
            logits = hW + b
            softmax(logits)
        """

        logits = h @ self.W + self.b

        exp = np.exp(logits - np.max(logits))
        probs = exp / np.sum(exp)

        return probs

    
def load_dataset(path):
    """
    Nacita dataset zo JSON suboru.

    Vstup:
        path (str): cesta k suboru

    Vystup:
        list[tuple]: [(input, output), ...]
    """

    with open(path, "r", encoding="utf-8") as f:
        raw = json.load(f)

    data = []
    for item in raw:
        data.append((item["input"], item["output"]))

    return data

def tokenize(text):
    """
    Rozdeli text na slova.

    Vstup:
        text (str)

    Vystup:
        list[str]
    """

    return text.lower().split()

def build_vocab(data, min_freq=1):
    """
    Vytvori slovnik slov s OOV tokenom.

    Vstup:
        data: dataset (input, output)
        min_freq: minimalna frekvencia slova

    Vystup:
        word2idx, idx2word

    Specialne tokeny:
        <PAD> - 0 padding (budeme potrebovat neskor)
        <UNK> - 1 neznama hodnota
    """

    counter = Counter()

    for inp, out in data:
        counter.update(tokenize(inp))
        counter.update(tokenize(out))

    vocab = ["<PAD>", "<UNK>"] # 0, 1,

    for word, freq in counter.items():
        if freq >= min_freq:
            vocab.append(word)

    word2idx = {w: i for i, w in enumerate(vocab)}
    idx2word = {i: w for w, i in word2idx.items()}

    return word2idx, idx2word

def encode_oov(tokens, word2idx):
    """
    Prevod tokenov na cisla.

    Vstup:
        tokens (list[str])
        word2idx (dict)

    Vystup:
        list[int]

    Logika:
        - ak slovo existuje -> index
        - ak nie -> <UNK>
    """

    unk_id = word2idx["<UNK>"]

    return [
        word2idx.get(token, unk_id)
        for token in tokens
    ]

def decode_debuger(indices, idx2word):
    """
    Prevod indexov spat na text.

    Vstup:
        indices (list[int])

    Vystup:
        str
    """

    return " ".join([idx2word[i] for i in indices])

def mean_pooling(embeddings):
    """
    Vypocita sentence representation pomocou mean pooling.

    Vstup:
        embeddings (np.array): tvar (n_words, embed_dim)

    Vystup:
        np.array: tvar (embed_dim,)

    Matematika:
        h = (1/n) * Σ e_i

    Vysvetlenie:
        Kazde slovo ma svoj embedding.
        Vsetky sa spriemeruju do jedneho vektora,
        ktory reprezentuje celu vetu.
    """

    return np.mean(embeddings, axis=0)

def cross_entropy(probs, target_idx):
    """
    Cross-entropy loss.

    Vstup:
        probs (np.array): pravdepodobnosti
        target_idx (int): spravne slovo

    Vystup:
        float: strata

    Matematika:
        L = -log(p(target))
    """

    return -np.log(probs[target_idx] + 1e-9)

def backward_classifier(model, h, probs, target_idx, lr):
    """
    Spatne sirenie chyby pre linear layer.

    Vstup:
        model: classifier
        h: sentence vector
        probs: softmax vystup
        target_idx: spravne slovo
        lr: learning rate

    Matematika:
        dL/dlogits = probs - one_hot(target)
    """

    dlogits = probs.copy()
    dlogits[target_idx] -= 1

    dW = np.outer(h, dlogits)
    db = dlogits

    dh = model.W @ dlogits

    model.W -= lr * dW
    model.b -= lr * db

    return dh

def train_step_(embedding, classifier, x, y_idx, lr):
    """
    Jeden training krok.

    Kroky:
        1. embedding lookup
        2. mean pooling
        3. forward classifier
        4. loss
        5. backprop
    """

    emb = embedding.forward(x)

    # sentence representation
    h = mean_pooling(emb)

    # forward
    probs = classifier.forward(h)

    loss = cross_entropy(probs, y_idx)

    # backprop classifier
    dh = backward_classifier(classifier, h, probs, y_idx, lr)

    # backprop embedding (jednoducho rozdelíme gradient)
    grad_emb = dh / len(x)

    embedding.update(x, grad_emb, lr)

    return loss

def train_step(embedding, classifier, x, y_idx, lr, idx2word):
    """
    Trening krok s detailnym vypisom co sa deje.
    """

    print("\n==============================")
    print("INPUT IDS:", x)
    print("INPUT WORDS:", [idx2word[i] for i in x])

    # 1. embedding
    emb = embedding.forward(x)
    print("\nEMBEDDINGS SHAPE:", emb.shape)
    print("EMBEDDINGS SAMPLE:", emb[0])

    # 2. sentence representation
    h = mean_pooling(emb)
    print("\nSENTENCE VECTOR:", h)

    # 3. forward pass
    logits = h @ classifier.W + classifier.b
    print("\nLOGITS:", logits)

    probs = np.exp(logits - np.max(logits))
    probs = probs / np.sum(probs)

    print("\nPROBS TOP 5:")

    top5 = np.argsort(probs)[-5:][::-1]
    for i in top5:
        print(f"{idx2word[i]}: {probs[i]:.4f}")

    # 4. target
    print("\nTARGET:", y_idx, idx2word[y_idx])

    # 5. loss
    loss = -np.log(probs[y_idx] + 1e-9)
    print("LOSS:", loss)

    # 6. backprop
    dlogits = probs.copy()
    dlogits[y_idx] -= 1

    print("\nGRADIENT SAMPLE:", dlogits[:5])

    # update classifier
    dW = np.outer(h, dlogits)
    db = dlogits
    dh = classifier.W @ dlogits

    classifier.W -= lr * dW
    classifier.b -= lr * db

    embedding.update(x, dh / len(x), lr)

    return loss

def train_(model_embed, model_clf, data, word2idx, epochs=300, lr=0.05):
    """
    Trenuje cely model.

    Vstup:
        model_embed: embedding vrstva
        model_clf: classifier
        data: dataset
        word2idx: slovnik
        epochs: pocet iteracii
    """

    for epoch in range(epochs):
        total_loss = 0

        for inp, out in data:
            x = encode_oov(tokenize(inp), word2idx)
            y = encode_oov(tokenize(out), word2idx)[0]

            loss = train_step(model_embed, model_clf, x, y, lr)
            total_loss += loss

        if epoch % 50 == 0:
            print(f"epoch {epoch}, loss {total_loss:.4f}")
            
        
def train(embedding, classifier, data, word2idx, idx2word, epochs=2, lr=0.05):
    """
    Trening s debug vypisom.
    """

    for epoch in range(epochs):
        print("\n##############################")
        print("EPOCH:", epoch)

        total_loss = 0

        for inp, out in data:
            x = encode_oov(tokenize(inp), word2idx)
            y = encode_oov(tokenize(out), word2idx)[0]

            loss = train_step(embedding, classifier, x, y, lr, idx2word)

            total_loss += loss

        print("\nEPOCH LOSS:", total_loss)

def predict(embedding, classifier, text, word2idx, idx2word):
    """
    Predikcia jedneho slova.

    Vstup:
        text (str): vstup
    Vystup:
        str: predikovane slovo
    """

    x = encode_oov(tokenize(text), word2idx)

    emb = embedding.forward(x)
    h = mean_pooling(emb)

    probs = classifier.forward(h)

    idx = np.argmax(probs)

    return idx2word[idx]

Našiel si ho — a zároveň ho už aj máš v hlave, len ho nevidíš ako „jedno číslo“.
📌 tvoja otázka: kde je x0 v TOMTO kóde?

V tvojom projekte nemáš klasické:

x0 = -0.5

lebo ty nerobíš 1D funkciu.

Ty máš vektorový problém (LLM).
🧠 kde je „x0“ v tvojom kóde

👉 x0 = všetky parametre, ktoré sa začnú náhodne

konkrétne:
🔹 1. embeddingy

self.E = np.random.randn(vocab_size, embed_dim) * 0.01

👉 toto je tvoj x0 pre embedding priestor
🔹 2. classifier váhy

self.W = np.random.randn(embed_dim, vocab_size) * 0.01
self.b = np.zeros(vocab_size)

👉 toto je druhý x0
⚙️ čo to znamená presne

Neural Network Initialization

👉 celý tvoj model začína ako:

    náhodne nastavená funkcia

📊 prečo to nie je jedna hodnota x0

Lebo:

    v 1D máš x0 = jedno číslo

    v LLM máš x0 = MILIÓNY čísel

🧠 správna interpretácia

Tvoj „x0“ nie je:

x0 = -0.5

ale:

x0 = všetky váhy modelu

🚶 čo sa deje potom

každý krok:

W = W - lr * dW
E = E - lr * dE

👉 to je tvoj „pohyb v krajine“
🔥 najdôležitejší insight

👉 v LLM neoptimalizuješ x
👉 optimalizuješ celý priestor parametrov
📌 takže odpoveď na tvoju otázku

    „kde sa nastavuje pociatocny bod?“

✔ v tvojom kóde:

    v np.random.randn(...)

    v np.zeros(...)

✔ to JE x0
🧠 jednoduchá mentálna mapa
1D príklad	tvoj LLM
x0	všetky váhy
x	všetky váhy počas tréningu
derivácia	gradienty matíc
🚀 ak chceš ďalší krok

vieme spraviť veľmi dôležitú vec:

👉 označiť presne „x0 → x1 → x2“ v tvojom embedding priestore
👉 alebo vizualizovať 2D projekciu (PCA) toho ako sa menia váhy počas tréningu
👉 alebo ukázať kde presne vzniká „učenie slova ahoj → mam“

Stačí povedať 👍

gradienty matíc? co to je?

„Gradienty matíc“ znie zložito, ale v tvojom kóde to je vlastne veľmi konkrétna vec: je to len derivácia (citlivosť) lossu voči každej bunke matice váh.
🧠 1. najprv 1D intuícia

V 1D si mal:

f(x) → číslo

gradient:

df/dx = číslo

👉 povie ti: „ako veľmi zmeniť x“
📌 2. teraz matica

V tvojom LLM máš napr.:

W = np.random.randn(embed_dim, vocab_size)

To je matica:

W =
[ w11 w12 w13 ...
  w21 w22 w23 ...
  ...           ]

🧠 3. čo je gradient matice

👉 je to MATICA rovnakého tvaru:

dL/dW =
[ ∂L/∂w11 ∂L/∂w12 ...
  ∂L/∂w21 ∂L/∂w22 ...
  ... ]

⚙️ 4. čo to znamená intuitívne

Každé číslo hovorí:

    „čo sa stane s lossom, ak zmením túto konkrétnu váhu“

📊 5. v tvojom kóde

Tu:

dW = np.outer(h, dlogits)

👉 toto je gradient matice W
🧠 čo sa tam deje

    h = sentence vector (vstup)

    dlogits = chyba výstupu

👉 outer product = rozdelenie chyby na všetky váhy
🔥 6. veľmi dôležitá intuícia

Gradient Descent

👉 gradient matice = „mapa citlivosti celého systému“
🚶 7. jednoduchá predstava

Predstav si:

    matica W = 1000 prepínačov

    každý prepínač ovplyvňuje výsledok

gradient povie:

    „ktorý prepínač zmeniť a o koľko“

📌 8. prečo je to dôležité v LLM

Neural Network

Lebo:

    neupravuješ 1 číslo

    upravuješ MILIÓNY čísiel naraz

🔥 9. úplne jednoduchá veta

👉 gradient matice = tabuľka „ako meniť každú váhu“
🚀 ak chceš ďalší krok

vieme spraviť:

👉 vizualizáciu gradientu ako heatmapu (fakt pomáha pochopiť)
👉 alebo ukázať ako jeden tréningový krok mení konkrétny riadok embeddingu
👉 alebo prepojiť: „ako sa zmení význam slova ahoj po 1 kroku“

Stačí povedať 👍

podme to spocitat rucne tu derivaciu f(x) = x^4 - 3x^3 + 2 ako najdem to minimum

Super, toto je presne ten moment, kde sa gradient descent dá pochopiť „na papieri“.

Máme funkciu:

f(x) = x^4 - 3x^3 + 2

📌 1. krok: derivácia

Derivácia hovorí:

    kde je sklon 0 (ploché miesto → kandidát na minimum/maximum)

Počítame:

f'(x) = 4x^3 - 9x^2

📌 2. nájdi kritické body

Minimum/maximum sú tam, kde:

f'(x) = 0

teda:

4x^3 - 9x^2 = 0

vyberieme spoločný faktor:

x^2 (4x - 9) = 0

📌 3. riešenia

x^2 = 0   → x = 0
4x - 9 = 0 → x = 9/4 = 2.25

👉 kandidáti sú:

x = 0
x = 2.25

📌 4. zisti čo je minimum

Použijeme druhú deriváciu:

f''(x) = 12x^2 - 18x

🔹 bod x = 0

f''(0) = 0

👉 neurčité (treba viac testovať)
🔹 bod x = 2.25

f''(2.25) = 12*(2.25^2) - 18*(2.25)
           > 0

👉 kladné → minimum
📌 5. vypočítaj hodnotu minima

f(2.25) = 2.25^4 - 3*(2.25^3) + 2

≈

≈ -3.05

🧠 výsledok

👉 lokálne (a tu aj globálne) minimum je:

x ≈ 2.25
f(x) ≈ -3.05

🚶 6. ako to robí gradient descent

Gradient Descent

Nevidí deriváciu „symbolicky“.

Robí:

x = x - lr * f'(x)

krok po kroku:

    začne napr. x = -0.5

    počíta sklon

    posúva sa dole

    skončí blízko 2.25

🔥 7. dôležitý insight

    matematika → nájdeš presné minimum

    ML → približuješ minimum iteráciami

🚀 ak chceš ďalší krok

Môžeme:

👉 spraviť tabuľku krokov gradient descentu (x0 → x1 → x2 …)
👉 alebo to vizualizovať v Pythone (pohyb bodu po krivke)
👉 alebo prepojiť na tvoj LLM (loss surface = rovnaký princíp, len v 1000D)

Stačí povedať 👍

no nie neskoci na 2.25 ak zacne x= -0.5

Správne — neskočí. Toto je presne pointa gradient descentu: ide postupne, nie „teleport“.

Pozrime to reálne na tvojej funkcii:

f(x) = x^4 - 3x^3 + 2
f'(x) = 4x^3 - 9x^2

📌 štart: x = -0.5

Spočítame gradient:

f'(-0.5) = 4(-0.125) - 9(0.25)
         = -0.5 - 2.25
         = -2.75

📌 update krok (gradient descent)

x1 = x0 - lr * f'(x0)

dajme napr. lr = 0.1:

x1 = -0.5 - 0.1 * (-2.75)
x1 = -0.5 + 0.275
x1 = -0.225

📌 čo sa stalo?

    išiel si z -0.5 → -0.225

    nie smerom na 2.25

    ale tam, kde je lokálne „nižšie“ podľa sklonu

🧠 kľúčová intuícia

Gradient Descent

Gradient descent:

    nepozná minimum
    iba „kam je dole práve teraz“

📊 prečo nejde priamo na 2.25

Lebo:

    2.25 je „globálna informácia“

    gradient je „lokálna informácia“

👉 nemáš mapu, iba sklon pod nohami
📌 čo sa deje ďalej

Z -0.225:

    znovu vypočítaš deriváciu

    spravíš ďalší krok

    a tak ďalej

postupne:

-0.5 → -0.225 → 0.1 → 1.2 → 2.0 → 2.25

(ak lr sedí)
🔥 dôležitý insight

👉 gradient descent NIE JE „skok na minimum“
👉 je to „opakované drobné opravy smeru“
🚀 ak chceš ďalší krok

Môžeme si spraviť:

👉 tabuľku všetkých krokov ručne (x, f(x), f'(x))
👉 alebo graf s bodom, ktorý sa hýbe
👉 alebo prepojenie na tvoj LLM (prečo sa embeddingy menia pomaly, nie naraz)

Stačí povedať 👍

dobre myslim ze chapem 1d podme na 2d animaciu

Super, toto je presne moment kde sa z 1D „čiary“ posúvame do reálneho sveta neurónových sietí.

V 2D už nehľadáš minimum na osi x, ale na ploche:
f(x,y)
f(x,y)

Predstav si to ako krajinu:

    x = východ–západ

    y = sever–juh

    f(x,y) = výška kopca (loss)

1. Príklad 2D funkcie (loss surface)

Použijeme jednoduchú, ale peknú funkciu:
f(x,y)=x2+y2
f(x,y)=x2+y2

Minimum je v bode (0,0).

Gradient (to je smer najväčšieho rastu):
∇f=(2x,2y)
∇f=(2x,2y)
2. Gradient descent (intuícia)

Aktualizácia:
x=x−lr⋅2x
x=x−lr⋅2x
y=y−lr⋅2y
y=y−lr⋅2y

Čiže:

    ideš opačným smerom než rast funkcie

    postupne „kĺžeš“ do stredu

3. Kód + animácia (matplotlib)

Toto ti vykreslí:

    kontúry funkcie (ako mapa kopca)

    pohyb bodu smerom k minimu

import numpy as np
import matplotlib.pyplot as plt

class GradientDescent2D:
    """
    Simulacia gradient descent v 2D priestore.
    """

    def f(self, x, y):
        """
        Funkcia loss.

        Vstup:
            x, y (float)

        Vystup:
            float
        """
        return x**2 + y**2

    def grad(self, x, y):
        """
        Gradient funkcie.

        Vstup:
            x, y (float)

        Vystup:
            tuple (df/dx, df/dy)
        """
        return 2*x, 2*y

    def run(self, x0, y0, lr=0.1, steps=20):
        """
        Gradient descent simulacia.

        Vstup:
            x0, y0 (float): start
            lr (float): learning rate
            steps (int): pocet krokov

        Vystup:
            list bodov trajektorie
        """

        path = [(x0, y0)]

        x, y = x0, y0

        for i in range(steps):
            gx, gy = self.grad(x, y)

            x = x - lr * gx
            y = y - lr * gy

            path.append((x, y))

        return np.array(path)


# --- vizualizacia ---

gd = GradientDescent2D()

# start bod (nahodny)
x0, y0 = 3, 3

path = gd.run(x0, y0, lr=0.2, steps=15)

# grid pre funkciu
x = np.linspace(-4, 4, 100)
y = np.linspace(-4, 4, 100)
X, Y = np.meshgrid(x, y)
Z = X**2 + Y**2

plt.figure(figsize=(6,6))

# kontury (mapa kopca)
plt.contour(X, Y, Z, levels=20)

# trajektoria gradient descent
plt.plot(path[:,0], path[:,1], 'ro-')

plt.title("Gradient descent v 2D")
plt.xlabel("x")
plt.ylabel("y")

plt.show()

