📦 Kompletný kód (s komentármi)

import numpy as np
import random

# =========================================================
# 📊 DATASET
# =========================================================
# Jednoduché konverzačné páry (input → output)
# cieľ: naučiť model odpovedať jedným slovom (prvé slovo odpovede)

data = [
    ("ahoj", "ahoj"),
    ("ahoj ako sa mas", "mam sa dobre"),
    ("ako sa mas", "mam sa fajn"),
    ("co robis", "rozpravam sa"),
    ("ako sa volaš", "som chatbot"),
    ("kolko mas rokov", "nemam vek"),
    ("co je tvoje meno", "som ai"),
    ("ako sa citis", "citim sa dobre"),
    ("co mas rad", "mam rad konverzacie"),
    ("kde byvas", "byvam v cloude"),
    ("co je dnes", "je pekny den"),
    ("co robis teraz", "pisem odpoved"),
    ("rozumies mi", "ano rozumiem"),
    ("co je ai", "umely agent"),
    ("ako fungujes", "pouzivam model"),
    ("co je python", "programovaci jazyk"),
    ("co je matematika", "veda o cislach"),
    ("co je laska", "je to pocit"),
    ("si realny", "som virtualny"),
    ("pomozes mi", "ano pomozem"),
]

# =========================================================
# 🔤 TOKENIZÁCIA
# =========================================================
# Funkcia rozdelí vetu na slová
# napr: "ahoj ako sa mas" → ["ahoj", "ako", "sa", "mas"]

def tokenize(text):
    return text.lower().split()


# =========================================================
# 📚 SLOVNÍK (VOCABULARY)
# =========================================================
# vytvoríme mapovanie:
# slovo → index (číslo)
# index → slovo

def build_vocab(data):
    vocab = set()
    
    for inp, out in data:
        vocab.update(tokenize(inp))
        vocab.update(tokenize(out))
    
    word2idx = {w: i for i, w in enumerate(vocab)}
    idx2word = {i: w for w, i in word2idx.items()}
    
    return word2idx, idx2word


# =========================================================
# 🔢 ENCODING
# =========================================================
# prevedie slová na čísla

def encode(tokens, word2idx):
    return [word2idx[t] for t in tokens]


# =========================================================
# 🧠 MODEL
# =========================================================
class SimpleLLM:
    def __init__(self, vocab_size, embed_size=16):
        """
        vocab_size = počet slov
        embed_size = veľkosť embedding vektora
        
        embed: matica (vocab_size x embed_size)
        W: váhy lineárnej vrstvy (embed_size x vocab_size)
        b: bias (vocab_size)
        """
        
        self.embed = np.random.randn(vocab_size, embed_size) * 0.1
        self.W = np.random.randn(embed_size, vocab_size) * 0.1
        self.b = np.zeros(vocab_size)

    def forward(self, x):
        """
        Forward pass (dopredný výpočet)
        
        KROKY:
        1. embedding lookup
        2. priemer embeddingov
        3. lineárna vrstva
        4. softmax
        
        Matematika:
        h = priemer(embeddingy)
        logits = hW + b
        softmax(logits)
        """
        
        emb = self.embed[x]  # (n_words, embed_size)
        h = np.mean(emb, axis=0)  # (embed_size,)
        
        logits = h @ self.W + self.b  # lineárna transformácia
        
        # softmax: prevod na pravdepodobnosti
        exp = np.exp(logits - np.max(logits))
        probs = exp / np.sum(exp)
        
        return probs, h, emb


# =========================================================
# 📉 STRATOVÁ FUNKCIA (LOSS)
# =========================================================
def loss_fn(probs, target):
    """
    Cross-entropy loss
    
    L = -log(p_target)
    
    kde:
    p_target = pravdepodobnosť správneho slova
    
    Táto funkcia:
    - penalizuje model, keď dá nízku pravdepodobnosť správnej odpovedi
    - minimum je 0 (keď p=1)
    """
    
    return -np.log(probs[target] + 1e-9)


# =========================================================
# 🔙 BACKPROPAGATION
# =========================================================
def backward(model, x, probs, h, emb, target, lr=0.05):
    """
    Spätné šírenie chyby (gradient descent)
    
    Kľúčová vec:
    derivácia cross-entropy + softmax:
    
    dL/dlogits = probs - one_hot(target)
    
    """
    
    # gradient výstupu
    dlogits = probs.copy()
    dlogits[target] -= 1  # toto je derivácia
    
    # gradient pre W a b
    dW = np.outer(h, dlogits)
    db = dlogits
    
    # gradient pre hidden vrstvu
    dh = model.W @ dlogits
    
    # gradient pre embeddingy (rovnomerne rozdelený)
    demb = dh / len(x)
    
    # update embeddingov
    for idx in x:
        model.embed[idx] -= lr * demb
    
    # update váh
    model.W -= lr * dW
    model.b -= lr * db


# =========================================================
# 🔁 TRÉNING
# =========================================================
def train(model, data, word2idx, epochs=500):
    for epoch in range(epochs):
        total_loss = 0
        
        for inp, out in data:
            x = encode(tokenize(inp), word2idx)
            y = encode(tokenize(out), word2idx)[0]
            
            probs, h, emb = model.forward(x)
            loss = loss_fn(probs, y)
            
            backward(model, x, probs, h, emb, y)
            total_loss += loss
        
        if epoch % 50 == 0:
            print(f"Epoch {epoch}, loss: {total_loss:.4f}")


# =========================================================
# 💬 GENEROVANIE
# =========================================================
def generate(model, text, word2idx, idx2word):
    tokens = tokenize(text)
    x = encode(tokens, word2idx)
    
    probs, _, _ = model.forward(x)
    idx = np.argmax(probs)
    
    return idx2word[idx]


# =========================================================
# 🚀 SPUSTENIE
# =========================================================
word2idx, idx2word = build_vocab(data)
model = SimpleLLM(len(word2idx))

train(model, data, word2idx)

print(generate(model, "ahoj ako sa mas", word2idx, idx2word))

